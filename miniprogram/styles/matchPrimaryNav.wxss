.match-primary-nav {
  margin-bottom: 16rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.match-primary-nav-item {
  min-height: 76rpx;
  border-radius: 999rpx;
  border: 1rpx solid #dce5ef;
  background: #f8fbff;
  color: #64748b;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 760;
}

.match-primary-nav-item.active {
  background: #16a34a;
  border-color: #16a34a;
  color: #ffffff;
  box-shadow: 0 10rpx 20rpx rgba(22, 163, 74, 0.16);
}
