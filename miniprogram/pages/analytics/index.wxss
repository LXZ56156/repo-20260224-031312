.analytics-page {
  padding-top: 24rpx;
}

.analytics-hero {
  padding: 28rpx;
}

.analytics-hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.analytics-hero-main {
  min-width: 0;
  flex: 1;
}

.hero-overline {
  font-size: 22rpx;
  letter-spacing: 0.18em;
  opacity: 0.78;
  text-transform: uppercase;
}

.analytics-share-btn {
  width: auto;
  min-width: 200rpx;
  padding: 0 24rpx;
}

.analytics-hero-headline {
  margin-top: 18rpx;
  font-size: 48rpx;
  line-height: 1.1;
  font-weight: 820;
}

.analytics-hero-stats {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
}

.analytics-hero-stat {
  padding: 12rpx 14rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.analytics-hero-stat-label {
  font-size: 22rpx;
  opacity: 0.86;
}

.analytics-hero-stat-value {
  font-size: 31rpx;
  font-weight: 760;
}

.analytics-hero-links {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.analytics-hero-link {
  font-size: 25rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.96);
}

.analytics-hero-link-muted {
  opacity: 0.86;
}

.sync-banner {
  margin-bottom: 12rpx;
  padding: 12rpx 16rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.sync-warning {
  background: #fef3c7;
  border: 1rpx solid #fcd34d;
  color: #92400e;
}

.sync-info {
  background: #eff6ff;
  border: 1rpx solid #bfdbfe;
  color: #1d4ed8;
}

.sync-neutral {
  background: #f8fafc;
  border: 1rpx solid #dbe5ef;
  color: #334155;
}

.sync-banner-main {
  flex: 1;
  min-width: 0;
}

.sync-banner-text {
  font-size: 23rpx;
  font-weight: 700;
}

.sync-banner-meta {
  margin-top: 4rpx;
  font-size: 21rpx;
  line-height: 1.5;
  opacity: 0.88;
}

.sync-banner-action {
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 760;
}

.summary-grid {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.summary-item {
  padding: 14rpx;
  border-radius: 16rpx;
  border: 1rpx solid #dde6f0;
  background: #f7fafd;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.summary-label {
  font-size: 22rpx;
  color: var(--text-2, #64748b);
}

.summary-value {
  font-size: 34rpx;
  font-weight: 780;
  color: var(--text-1, #0f172a);
}

.report-card {
  border-style: solid;
}

.report-headline {
  margin-top: 10rpx;
  padding: 12rpx 14rpx;
  border-radius: 14rpx;
  border: 1rpx solid #dbe5ef;
  background: #f7fafd;
  font-size: 25rpx;
  font-weight: 760;
  color: #0f172a;
}

.report-line {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #1e293b;
  line-height: 1.6;
}

.analytics-text-actions {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.analytics-text-link {
  font-size: 24rpx;
  font-weight: 700;
  color: #0f6a40;
}

.ad-breakpoint {
  margin-top: 14rpx;
  padding: 16rpx;
  border-radius: 18rpx;
  border: 1rpx dashed #cfe0ef;
  background: #f8fbff;
}

.ad-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 3rpx 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid #dbe5ef;
  background: #ffffff;
  color: #64748b;
  font-size: 21rpx;
  margin-bottom: 8rpx;
}

.top-list {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.top-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  padding: 14rpx;
  border-radius: 16rpx;
  background: #f7fafd;
  border: 1rpx solid #dde6f0;
}

.top-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.top-rank {
  min-width: 88rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: #e8f7ee;
  color: #166534;
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
}

.top-name {
  font-size: 28rpx;
  font-weight: 760;
}

.top-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 2rpx;
}

.top-metric {
  font-size: 24rpx;
  font-weight: 700;
}

.stats-head {
  margin-top: 12rpx;
  border-top: 1rpx solid #e6edf5;
  border-bottom: 1rpx solid #e6edf5;
  background: #f7fafd;
}

.stats-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 4rpx;
}

.col-rank {
  width: 42rpx;
  font-size: 23rpx;
  color: #64748b;
  font-weight: 700;
}

.analytics-expand-link {
  margin-top: 12rpx;
  display: inline-flex;
  color: #0f6a40;
  font-size: 24rpx;
  font-weight: 700;
}

.col-name {
  flex: 1.4;
  min-width: 0;
  font-size: 24rpx;
}

.col-num {
  flex: 1;
  text-align: right;
  font-size: 23rpx;
  color: #334155;
}

.activity-block {
  margin-top: 14rpx;
}

.activity-title {
  margin-bottom: 8rpx;
  font-size: 25rpx;
  font-weight: 760;
}

.activity-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #edf2f7;
}

.activity-item:last-child {
  border-bottom: 0;
}

.activity-label {
  flex: 1;
  min-width: 0;
  line-height: 1.45;
}

.activity-count {
  white-space: nowrap;
  font-size: 23rpx;
  font-weight: 700;
  color: #166534;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 760;
  margin-bottom: 8rpx;
}

.retry-box {
  margin-top: 16rpx;
  padding: 14rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--line-soft, #dbe5ef);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}
