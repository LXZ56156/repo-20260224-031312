.analytics-page {
  padding-top: 24rpx;
}

.offline-banner {
  margin-bottom: 12rpx;
  padding: 10rpx 14rpx;
  border-radius: 14rpx;
  background: #fef3c7;
  border: 1rpx solid #fcd34d;
  color: #92400e;
  font-size: 23rpx;
}

.hero-actions {
  margin-top: 14rpx;
  display: flex;
  gap: 12rpx;
}

.hero-actions .btn {
  width: auto;
  padding: 0 24rpx;
}

.summary-grid {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.summary-item {
  padding: 14rpx;
  border-radius: 16rpx;
  border: 1rpx solid #dde6f0;
  background: #f7fafd;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.summary-label {
  font-size: 22rpx;
  color: var(--text-2, #64748b);
}

.summary-value {
  font-size: 34rpx;
  font-weight: 780;
  color: var(--text-1, #0f172a);
}

.top-list {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.top-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  padding: 14rpx;
  border-radius: 16rpx;
  background: #f7fafd;
  border: 1rpx solid #dde6f0;
}

.top-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.top-rank {
  min-width: 88rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: #dcfce7;
  color: #166534;
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
}

.top-name {
  font-size: 28rpx;
  font-weight: 760;
}

.top-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 2rpx;
}

.top-metric {
  font-size: 24rpx;
  font-weight: 700;
}

.stats-head {
  margin-top: 12rpx;
  border-top: 1rpx solid #e6edf5;
  border-bottom: 1rpx solid #e6edf5;
  background: #f7fafd;
}

.stats-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 4rpx;
}

.col-name {
  flex: 1.6;
  min-width: 0;
  font-size: 24rpx;
}

.col-num {
  flex: 1;
  text-align: right;
  font-size: 23rpx;
  color: #334155;
}

.activity-block {
  margin-top: 14rpx;
}

.activity-title {
  margin-bottom: 8rpx;
  font-size: 25rpx;
  font-weight: 760;
}

.activity-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #edf2f7;
}

.activity-item:last-child {
  border-bottom: 0;
}

.activity-count {
  white-space: nowrap;
  font-size: 23rpx;
  font-weight: 700;
  color: #166534;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 760;
  margin-bottom: 8rpx;
}

.retry-box {
  margin-top: 16rpx;
  padding: 14rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--line-soft, #dbe5ef);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}
