/* ============================================================
   Analytics Page — 赛后战报风
   ============================================================ */

.analytics-page {
  padding-top: 24rpx;
}

/* --- Hero: 战报感强化 --- */
.analytics-hero {
  padding: 32rpx 28rpx;
}

.analytics-hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.analytics-hero-main {
  min-width: 0;
  flex: 1;
}

.hero-overline {
  font-size: 22rpx;
  letter-spacing: 0.22em;
  opacity: 0.82;
  text-transform: uppercase;
}

.analytics-hero-headline {
  margin-top: 20rpx;
  font-size: 52rpx;
  line-height: 1.08;
  font-weight: 820;
  letter-spacing: -0.5rpx;
  color: #ffffff;
}

.analytics-hero-stats {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
}

.analytics-hero-stat {
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.analytics-hero-stat-label {
  font-size: 22rpx;
  opacity: 0.86;
}

.analytics-hero-stat-value {
  font-size: 34rpx;
  font-weight: 800;
  letter-spacing: -0.3rpx;
}

.analytics-hero-links {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.analytics-hero-link {
  font-size: 25rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.96);
}

.analytics-hero-link-muted {
  opacity: 0.86;
}

/* --- Report Card: 首屏焦点 --- */
.report-card {
  border-left: 6rpx solid var(--brand-500);
  border-color: var(--brand-500);
}

.report-card .section-title {
  color: var(--brand-700);
}

.report-headline {
  margin-top: 14rpx;
  padding: 16rpx 18rpx;
  border-radius: 14rpx;
  border: 1rpx solid var(--brand-100);
  background: var(--brand-50);
  font-size: 28rpx;
  font-weight: 780;
  line-height: 1.45;
  color: var(--neutral-950);
}

.report-line {
  margin-top: 10rpx;
  font-size: 25rpx;
  color: var(--neutral-700);
  line-height: 1.65;
}

.analytics-text-actions {
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid var(--neutral-200);
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.analytics-text-link {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--brand-600);
}

/* --- Summary: metric-card 风格 --- */
.summary-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.summary-item.metric-card {
  padding: 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--neutral-200);
  background: var(--bg-section);
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.summary-label.metric-card-label {
  font-size: 22rpx;
  color: var(--neutral-500);
}

.summary-value.metric-card-value {
  font-size: 36rpx;
  font-weight: 800;
  letter-spacing: -0.3rpx;
  color: var(--neutral-950);
}

/* --- Ad slot --- */
.ad-breakpoint {
  margin-top: 14rpx;
  padding: 16rpx;
  border-radius: 18rpx;
  border: 1rpx dashed #cfe0ef;
  background: #f8fbff;
}

.ad-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 3rpx 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--neutral-200);
  background: #ffffff;
  color: var(--neutral-500);
  font-size: 21rpx;
  margin-bottom: 8rpx;
}

/* --- TOP 3: 自适应列数卡片（2 或 3 人/队时自动伸缩） --- */
.top-cards {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(0, 1fr));
  gap: 10rpx;
}

.top-card {
  padding: 16rpx 12rpx;
  border-radius: 16rpx;
  background: var(--bg-section);
  border: 1rpx solid var(--neutral-200);
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 4rpx;
  min-width: 0;
}

.top-card-gold {
  background: linear-gradient(135deg, #FFFBEB 0%, #FEF3C7 100%);
  border-color: #FCD34D;
}

.top-card-silver {
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-color: #CBD5E1;
}

.top-card-bronze {
  background: linear-gradient(135deg, #FFF7ED 0%, #FFEDD5 100%);
  border-color: #FDBA74;
}

.top-card-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  background: var(--neutral-100);
  color: var(--neutral-500);
}

.top-card-badge-gold {
  background: #FDE68A;
  color: #92400E;
}

.top-card-badge-silver {
  background: #E2E8F0;
  color: #475569;
}

.top-card-badge-bronze {
  background: #FED7AA;
  color: #9A3412;
}

.top-card-title {
  margin-top: 6rpx;
  font-size: 28rpx;
  font-weight: 760;
  color: var(--neutral-950);
  width: 100%;
}

.top-card-subtitle {
  font-size: 21rpx;
  color: var(--neutral-500);
  line-height: 1.35;
  width: 100%;
}

.top-card-metric {
  margin-top: 4rpx;
  font-size: 23rpx;
  font-weight: 700;
  color: var(--neutral-700);
}

.top-card-metric-sub {
  font-size: 21rpx;
}

/* --- 完整排名: 折叠式 + 紧凑表格 --- */
.ranking-section-head {
  cursor: pointer;
}

.ranking-toggle-group {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.ranking-toggle-arrow {
  font-size: 23rpx;
  font-weight: 700;
  color: var(--brand-600);
  transition: transform 200ms ease;
}

.ranking-toggle-arrow.expanded {
  /* expanded state styling */
}

.ranking-table-wrap {
  margin-top: 8rpx;
}

.stats-head {
  margin-top: 8rpx;
  border-top: 1rpx solid var(--neutral-200);
  border-bottom: 1rpx solid var(--neutral-200);
  background: var(--bg-section);
}

.stats-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 4rpx;
}

.stats-row + .stats-row {
  border-top: 1rpx solid var(--neutral-100);
}

.col-rank {
  width: 40rpx;
  font-size: 23rpx;
  color: var(--neutral-500);
  font-weight: 700;
}

.col-name {
  flex: 1.4;
  min-width: 0;
  font-size: 24rpx;
  color: var(--neutral-950);
}

.col-num {
  flex: 1;
  text-align: right;
  font-size: 23rpx;
  color: var(--neutral-700);
}

.stats-head .col-num,
.stats-head .col-name,
.stats-head .col-rank {
  color: var(--neutral-500);
  font-weight: 600;
  font-size: 22rpx;
}

/* --- 更多看点 --- */
.activity-block {
  margin-top: 14rpx;
}

.activity-title {
  margin-bottom: 8rpx;
  font-size: 25rpx;
  font-weight: 760;
  color: var(--neutral-950);
}

.activity-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx solid var(--neutral-100);
}

.activity-item:last-child {
  border-bottom: 0;
}

.activity-label {
  flex: 1;
  min-width: 0;
  line-height: 1.45;
  font-size: 25rpx;
  color: var(--neutral-700);
}

.activity-count {
  flex-shrink: 0;
  white-space: nowrap;
  font-size: 23rpx;
  font-weight: 700;
  color: var(--brand-700);
}

/* --- 空态 / 重试 --- */
.retry-box {
  margin-top: 16rpx;
  padding: 14rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--neutral-200);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}
