<view class="container safe-bottom analytics-page" wx:if="{{tournament}}">
  <view class="sync-banner sync-{{syncStatusTone}}" wx:if="{{syncStatusVisible}}">
    <view class="sync-banner-main">
      <view class="sync-banner-text">{{syncStatusText}}</view>
      <view class="sync-banner-meta" wx:if="{{syncStatusMeta}}">{{syncStatusMeta}}</view>
    </view>
    <text class="sync-banner-action" bindtap="onRetry">{{syncStatusActionText}}</text>
  </view>

  <view class="hero analytics-hero reveal reveal-1">
    <view class="analytics-hero-top">
      <view class="analytics-hero-main">
        <view class="hero-overline">赛事复盘</view>
        <view class="hero-title">{{tournament.name}}</view>
        <view class="hero-sub">{{modeLabel}} · {{statusLabel}}</view>
      </view>
    </view>
    <view class="analytics-hero-headline">{{heroHeadline}}</view>
    <view class="analytics-hero-stats">
      <view class="analytics-hero-stat" wx:for="{{heroStats}}" wx:key="label">
        <text class="analytics-hero-stat-label">{{item.label}}</text>
        <text class="analytics-hero-stat-value">{{item.value}}</text>
      </view>
    </view>
    <view class="analytics-hero-links">
      <text class="analytics-hero-link" bindtap="cloneCurrentTournament">再办一场</text>
    </view>
  </view>

  <view class="card panel reveal reveal-2" wx:if="{{summary}}">
    <view class="section-head">
      <view class="section-title">关键数据</view>
      <text class="count-pill">{{summary.finishedMatches}} / {{summary.totalMatches}}</text>
    </view>
    <view class="summary-grid">
      <view class="summary-item" wx:for="{{summaryStats}}" wx:key="label">
        <text class="summary-label">{{item.label}}</text>
        <text class="summary-value">{{item.value}}</text>
      </view>
    </view>
  </view>

  <view class="card panel report-card reveal reveal-3" wx:if="{{focusFacts.length}}">
    <view class="section-head">
      <view class="section-title">比赛结论</view>
      <text class="count-pill">{{statusLabel}}</text>
    </view>
    <view class="report-headline" wx:if="{{reportHeadline}}">{{reportHeadline}}</view>
    <view class="report-line" wx:for="{{focusFacts}}" wx:key="index">{{item}}</view>
    <view class="analytics-text-actions">
      <text class="analytics-text-link" bindtap="copyBriefReport">复制摘要</text>
      <text class="analytics-text-link" bindtap="copyBattleReport">复制完整战报</text>
    </view>
  </view>

  <view class="card panel-soft ad-breakpoint reveal reveal-4" wx:if="{{showAnalyticsAdSlot}}">
    <view class="ad-badge">广告</view>
  </view>

  <view class="card panel reveal reveal-5" wx:if="{{top3.length}}">
    <view class="section-head">
      <view class="section-title">{{topSectionTitle}}</view>
      <text class="count-pill">{{rankingTitle}}</text>
    </view>
    <view class="top-list">
      <view class="top-item" wx:for="{{top3}}" wx:key="playerId">
        <view class="top-left">
          <text class="top-rank">{{item.rankLabel}}</text>
          <text class="top-name ellipsis">{{item.name}}</text>
        </view>
        <view class="top-right">
          <text class="top-metric">胜{{item.wins}} 负{{item.losses}}</text>
          <text class="muted small">净胜 {{item.pointDiff}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="card panel reveal reveal-6" wx:if="{{fullRankings.length}}">
    <view class="section-head">
      <view class="section-title">完整排名</view>
      <text class="count-pill">{{playerStats.length}} {{rankingUnit}}</text>
    </view>

    <view class="stats-head stats-row">
      <text class="col-rank">#</text>
      <text class="col-name">{{rankingUnit==='队' ? '队伍' : '球员'}}</text>
      <text class="col-num">胜负</text>
      <text class="col-num">胜率</text>
      <text class="col-num">净胜</text>
    </view>
    <view class="stats-row" wx:for="{{displayRankings}}" wx:key="playerId">
      <text class="col-rank">{{item.rank}}</text>
      <text class="col-name ellipsis">{{item.name}}</text>
      <text class="col-num">{{item.wins}}/{{item.losses}}</text>
      <text class="col-num">{{item.winRate}}</text>
      <text class="col-num">{{item.pointDiff}}</text>
    </view>
    <text class="analytics-expand-link" wx:if="{{fullRankings.length > 5}}" bindtap="toggleRankingRows">{{showAllRankings ? '收起完整排名' : '展开完整排名'}}</text>
  </view>

  <view class="card panel reveal reveal-7" wx:if="{{summary && summary.finishedMatches>0 && (pairHot.length || duelHot.length)}}">
    <view class="section-head">
      <view class="section-title">更多看点</view>
      <text class="count-pill">完赛场次</text>
    </view>

    <view class="activity-block" wx:if="{{pairHot.length}}">
      <view class="activity-title">高频搭档</view>
      <view class="activity-item" wx:for="{{pairHot}}" wx:key="key">
        <text class="activity-label">{{item.label}}</text>
        <text class="activity-count">{{item.count}} 次</text>
      </view>
    </view>

    <view class="activity-block" wx:if="{{duelHot.length}}">
      <view class="activity-title">高频对阵</view>
      <view class="activity-item" wx:for="{{duelHot}}" wx:key="key">
        <text class="activity-label">{{item.label}}</text>
        <text class="activity-count">{{item.count}} 次</text>
      </view>
    </view>
  </view>

  <view class="card panel panel-soft reveal reveal-7" wx:if="{{summary && summary.finishedMatches===0}}">
    <view class="empty-title">暂无可复盘数据</view>
  </view>

  <view class="retry-box panel-soft" wx:if="{{canRetryAction}}">
    <view class="muted small">{{lastFailedActionText}}</view>
    <button class="btn btn-subtle btn-sm" bindtap="retryLastAction">重试上次操作</button>
  </view>
</view>

<view class="container safe-bottom" wx:elif="{{loadError}}">
  <view class="card panel reveal reveal-1">
    <view class="empty-title">加载失败</view>
    <view class="muted">请检查网络后重试。</view>
    <button class="btn btn-subtle" bindtap="onRetry">重新加载</button>
  </view>
</view>

<view class="container safe-bottom" wx:else>
  <view class="card panel reveal reveal-1">
    <view class="empty-title">加载中...</view>
    <view class="muted">正在同步最新赛事数据。</view>
  </view>
</view>
