/* ============================================================
   Launch 页面 — 赛制选择面板
   ============================================================ */

.launch-page {
  padding-bottom: 40rpx;
}

/* --- Hero --- */
.launch-hero {
  padding: 32rpx 24rpx 24rpx;
  border-radius: 24rpx;
  background:
    radial-gradient(ellipse at 85% 15%, rgba(255,255,255,0.18) 0%, transparent 50%),
    linear-gradient(135deg, var(--brand-700) 0%, var(--brand-500) 55%, #2DD47A 100%);
  color: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(24, 179, 104, 0.14);
}

.launch-hero-title {
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.2;
  letter-spacing: -0.3rpx;
}

.launch-hero-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  opacity: 0.85;
  line-height: 1.45;
}

/* --- Mode Card --- */
.launch-card {
  margin-top: 16rpx;
  position: relative;
  overflow: hidden;
}

/* 左侧色彩暗示条 */
.launch-card-accent {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  border-radius: 20rpx 0 0 20rpx;
  background: var(--neutral-300);
  transition: background 200ms ease;
}

/* 不同模式的色彩暗示 */
.launch-card-multi_rotate .launch-card-accent {
  background: var(--brand-500);
}

.launch-card-squad_doubles .launch-card-accent {
  background: var(--info-500);
}

.launch-card-fixed_pair_rr .launch-card-accent {
  background: #F59E0B;
}

/* 默认推荐模式 — 轻微强调 */
.launch-card.is-default {
  border-color: rgba(24, 179, 104, 0.3);
  box-shadow: 0 4rpx 16rpx rgba(24, 179, 104, 0.12);
}

.launch-card.is-default .launch-card-accent {
  width: 8rpx;
}

.launch-row {
  align-items: flex-start;
  gap: 12rpx;
  padding-left: 8rpx;
}

.launch-title {
  font-size: 32rpx;
  font-weight: 780;
  line-height: 1.3;
  color: var(--neutral-950);
}

.launch-sub {
  margin-top: 8rpx;
  line-height: 1.5;
  color: var(--neutral-500);
  font-size: 24rpx;
}

.launch-actions {
  margin-top: 16rpx;
  padding-left: 8rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

/* 规则说明 — text link 弱化 */
.launch-rule-link {
  color: var(--neutral-500);
  font-size: 24rpx;
  font-weight: 500;
  text-decoration: underline;
  text-underline-offset: 4rpx;
}

/* 发起按钮 — primary CTA */
.launch-btn {
  min-width: 160rpx;
}
