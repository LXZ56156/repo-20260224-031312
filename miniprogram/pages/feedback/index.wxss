/* feedback — 轻对话式反馈页 */

.feedback-page {
  gap: 20rpx;
}

.feedback-block {
  margin-top: 0;
}

.feedback-block .btn + .btn {
  margin-top: 12rpx;
}

.feedback-block-title {
  font-size: 30rpx;
  font-weight: 740;
  color: var(--neutral-950);
  margin-bottom: 10rpx;
}

.feedback-actions {
  margin-top: 12rpx;
}
