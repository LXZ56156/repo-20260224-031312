<view class="container safe-bottom settings-page" wx:if="{{tournament}}">
  <view class="sync-banner sync-{{syncStatusTone}}" wx:if="{{syncStatusVisible}}">
    <view class="sync-banner-main">
      <view class="sync-banner-text">{{syncStatusText}}</view>
      <view class="sync-banner-meta" wx:if="{{syncStatusMeta}}">{{syncStatusMeta}}</view>
    </view>
    <text class="sync-banner-action" bindtap="onRetry">{{syncStatusActionText}}</text>
  </view>

  <view class="hero">
    <view class="hero-title">{{pageTitle}}</view>
  </view>

  <view class="card panel panel-soft context-panel">
    <view class="section-head">
      <view class="section-title">{{contextTitle}}</view>
      <text class="count-pill">{{mandatoryDone}} / {{mandatoryTotal}}</text>
    </view>
  </view>

  <view class="card panel settings-panel" id="section-params">
    <view class="row row-top">
      <view class="section-title">修改比赛</view>
      <text class="status-pill {{settingsReady ? 'ok' : 'pending'}}">{{settingsReady ? '已完成' : '待完成'}}</text>
    </view>

    <view class="form-item">
      <view class="form-label">赛事名称</view>
      <view class="form-field">
        <input
          class="picker input-like {{isAdmin && tournament.status==='draft' ? '' : 'disabled'}}"
          placeholder="请输入赛事名称"
          value="{{name}}"
          bindinput="onNameInput"
          disabled="{{!(isAdmin && tournament.status==='draft')}}"
        />
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">总场次</view>
      <view class="form-field">
        <block wx:if="{{isAdmin && tournament.status==='draft'}}">
          <picker wx:if="{{useSimpleMPicker}}" mode="selector" range="{{mOptions}}" value="{{mIndex}}" bindchange="onPickTotalMatchesSimple">
            <view class="picker">{{editM}}</view>
          </picker>
          <picker wx:else mode="multiSelector" range="{{mDigitRange}}" value="{{mDigitValue}}" bindchange="onPickTotalMatches">
            <view class="picker">{{editM}}</view>
          </picker>
        </block>
        <block wx:else>
          <view class="picker disabled">{{tournament.totalMatches || '—'}}</view>
        </block>
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">每轮最多场数</view>
      <view class="form-field">
        <block wx:if="{{isAdmin && tournament.status==='draft'}}">
          <picker mode="selector" range="{{courtOptions}}" value="{{courtIndex}}" bindchange="onPickCourts">
            <view class="picker">{{editC}}</view>
          </picker>
        </block>
        <block wx:else>
          <view class="picker disabled">{{tournament.courts || '—'}}</view>
        </block>
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">活动时长</view>
      <view class="form-field">
        <block wx:if="{{isAdmin && tournament.status==='draft'}}">
          <picker mode="selector" range="{{sessionMinuteOptions}}" value="{{sessionMinuteIndex}}" bindchange="onPickSessionMinutes">
            <view class="picker">{{sessionMinutes}} 分钟</view>
          </picker>
        </block>
        <block wx:else>
          <view class="picker disabled">{{sessionMinutes}} 分钟</view>
        </block>
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">单场占用时间</view>
      <view class="form-field">
        <block wx:if="{{isAdmin && tournament.status==='draft'}}">
          <picker mode="selector" range="{{slotMinuteOptions}}" value="{{slotMinuteIndex}}" bindchange="onPickSlotMinutes">
            <view class="picker">{{slotMinutes}} 分钟</view>
          </picker>
        </block>
        <block wx:else>
          <view class="picker disabled">{{slotMinutes}} 分钟</view>
        </block>
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">每局分制</view>
      <view class="form-field">
        <block wx:if="{{isAdmin && tournament.status==='draft'}}">
          <picker mode="selector" range="{{pointsOptions}}" value="{{pointsIndex}}" bindchange="onPickPointsPerGame">
            <view class="picker">{{pointsPerGame}} 分</view>
          </picker>
        </block>
        <block wx:else>
          <view class="picker disabled">{{pointsPerGame}} 分</view>
        </block>
      </view>
    </view>

    <view class="form-item" wx:if="{{showSquadEndCondition}}">
      <view class="form-label">结束条件</view>
      <view class="form-field">
        <block wx:if="{{isAdmin && tournament.status==='draft'}}">
          <picker mode="selector" range="{{endConditionOptions}}" range-key="label" value="{{endConditionIndex}}" bindchange="onPickEndConditionType">
            <view class="picker">{{endConditionOptions[endConditionIndex].label}}</view>
          </picker>
        </block>
        <block wx:else>
          <view class="picker disabled">{{endConditionOptions[endConditionIndex].label}}</view>
        </block>
      </view>
    </view>

    <view class="form-item" wx:if="{{showSquadEndCondition}}">
      <view class="form-label">{{endConditionTargetLabel}}</view>
      <view class="form-field">
        <block wx:if="{{isAdmin && tournament.status==='draft' && showEndConditionTargetPicker}}">
          <picker mode="selector" range="{{endConditionTargetOptions}}" value="{{endConditionTargetIndex}}" bindchange="onPickEndConditionTarget">
            <view class="picker">{{endConditionTarget}} {{endConditionTargetUnit}}</view>
          </picker>
        </block>
        <block wx:elif="{{showSquadEndCondition}}">
          <view class="picker disabled">{{endConditionTarget}} {{endConditionTargetUnit}}</view>
        </block>
      </view>
    </view>

    <button class="btn btn-primary settings-save" bindtap="saveSettings" loading="{{settingsBusy}}" disabled="{{settingsBusy}}" wx:if="{{isAdmin && tournament.status==='draft'}}">保存修改</button>
  </view>

  <view class="retry-box panel-soft" wx:if="{{canRetryAction}}">
    <view class="muted small">{{lastFailedActionText}}</view>
    <button class="btn btn-subtle btn-sm" bindtap="retryLastAction">重试上次操作</button>
  </view>
</view>

<view class="container safe-bottom settings-page" wx:elif="{{loadError}}">
  <view class="card panel">
    <view class="state-title">{{loadErrorTitle}}</view>
    <view class="muted">{{loadErrorMessage}}</view>
    <button class="btn btn-subtle" bindtap="onRetry">重新加载</button>
    <button class="btn btn-ghost" bindtap="goHome" wx:if="{{showLoadErrorHome}}">返回首页</button>
  </view>
</view>

<view class="container safe-bottom settings-page" wx:else>
  <view class="card panel">
    <view class="state-title">加载中...</view>
    <view class="muted">正在同步赛事设置。</view>
  </view>
</view>
