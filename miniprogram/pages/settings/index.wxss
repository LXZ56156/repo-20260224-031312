/* settings — 比赛设置中心 */

.settings-page {
  padding-top: 20rpx;
}

/* Panels */
.settings-panel {
  padding: 20rpx;
}

.context-panel {
  padding: 20rpx;
}

/* Status pill */
.status-pill {
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--neutral-200);
  background: var(--neutral-100);
  color: var(--neutral-500);
  font-size: 22rpx;
  font-weight: 600;
}

.status-pill.ok {
  background: #DCFCE7;
  border-color: #86EFAC;
  color: #166534;
}

.status-pill.pending {
  background: #FEF3C7;
  border-color: #FCD34D;
  color: #92400E;
}

.status-pill.optional {
  background: var(--neutral-100);
  border-color: var(--neutral-200);
  color: var(--neutral-500);
}

/* Form items — horizontal layout for settings */
.form-item {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.form-label {
  width: 170rpx;
  flex-shrink: 0;
  font-size: 25rpx;
  color: var(--neutral-500);
  font-weight: 500;
}

.form-field {
  flex: 1;
}

.picker {
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 14rpx;
  border: 1rpx solid var(--neutral-200);
  background: var(--neutral-100);
  padding: 0 18rpx;
  font-size: 28rpx;
  color: var(--neutral-950);
}

.picker.disabled {
  color: var(--neutral-500);
  background: var(--neutral-50);
}

.input-like {
  width: 100%;
  box-sizing: border-box;
}

.settings-save {
  margin-top: 20rpx;
}

/* row-top in settings context */
.row-top {
  justify-content: space-between;
}

/* State title */
.state-title {
  font-size: 30rpx;
  font-weight: 740;
  margin-bottom: 8rpx;
}

/* Referee section (if present) */
.referee-current {
  margin-top: 14rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.referee-current.set {
  background: #FEF3C7;
  border: 1rpx solid #FCD34D;
}

.referee-current.unset {
  background: var(--neutral-100);
  border: 1rpx solid var(--neutral-200);
}

.referee-left {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.referee-name {
  font-size: 30rpx;
  font-weight: 780;
  color: var(--neutral-950);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.referee-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.referee-btn {
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 16rpx;
  border-radius: 14rpx;
  font-size: 25rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.referee-btn.primary {
  background: var(--brand-500);
  color: #fff;
}

button.referee-btn::after {
  border: none;
}

/* Players */
.players {
  margin-top: 14rpx;
}

.player {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--neutral-100);
}

.player:last-child {
  border-bottom: 0;
}

.player-name {
  font-size: 27rpx;
  color: var(--neutral-950);
  font-weight: 600;
}

.player-main {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.player-gender-chip {
  min-width: 64rpx;
  text-align: center;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: var(--neutral-100);
  border: 1rpx solid var(--neutral-200);
  color: var(--neutral-700);
  font-size: 22rpx;
  font-weight: 600;
}

/* Retry */
.retry-box {
  margin-top: 16rpx;
  padding: 12rpx 16rpx;
  border-radius: 14rpx;
  border: 1rpx solid var(--neutral-200);
  background: var(--bg-section);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}
