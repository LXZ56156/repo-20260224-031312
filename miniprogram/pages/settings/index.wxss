.players-table{margin-top:10rpx;}
.list-item{display:flex;align-items:center;justify-content:space-between;gap:16rpx;padding:16rpx 0;border-bottom:1rpx solid #eef2f7;}
.list-item:last-child{border-bottom:0;}
.player-name{font-weight:700;color:#0f172a;}
.player-meta{margin-top:6rpx;}

.chip-btn{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  padding: 10rpx 18rpx;
}

.referee-current{ margin-top: 14rpx; padding: 18rpx 16rpx; border-radius: 16rpx; display:flex; align-items:center; gap: 14rpx; }
.referee-current.set{ background:#FEF3C7; border:1rpx solid #FCD34D; }
.referee-current.unset{ background:#F3F4F6; border:1rpx solid #E5E7EB; }
.referee-left{ flex:1; min-width:0; display:flex; flex-direction:column; gap: 6rpx; }
.referee-name{ font-size: 32rpx; font-weight: 900; color:#111827; max-width: 420rpx; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.referee-badge{ padding: 6rpx 14rpx; border-radius:999rpx; background:#FEF3C7; color:#B45309; border:1rpx solid #FCD34D; font-size: 24rpx; font-weight: 800; }

.referee-actions{ display:flex; align-items:center; gap: 12rpx; }
.referee-btn{
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 18rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 800;
  display:flex;
  align-items:center;
  justify-content:center;
}
.referee-btn.primary{ background:#16A34A; color:#fff; }
.referee-btn.ghost{ background:#F3F4F6; color:#111827; }
button.referee-btn::after{ border:none; }

.picker.disabled{ color:#9CA3AF; background:#F3F4F6; }

/* 参赛者列表更紧凑 */
.players{ margin-top: 14rpx; }
.player{ display:flex; align-items:center; justify-content:space-between; gap: 12rpx; padding: 12rpx 0; border-bottom: 1rpx solid #EEF2F7; }
.player:last-child{ border-bottom: 0; }
.player-name{ font-size: 28rpx; color:#111827; font-weight: 700; }
