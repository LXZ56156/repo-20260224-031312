.settings-page {
  padding-top: 24rpx;
}

.sync-banner {
  margin-bottom: 12rpx;
  padding: 12rpx 16rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.sync-warning {
  background: #fef3c7;
  border: 1rpx solid #fcd34d;
  color: #92400e;
}

.sync-info {
  background: #eff6ff;
  border: 1rpx solid #bfdbfe;
  color: #1d4ed8;
}

.sync-neutral {
  background: #f8fafc;
  border: 1rpx solid #dbe5ef;
  color: #334155;
}

.sync-banner-main {
  flex: 1;
  min-width: 0;
}

.sync-banner-text {
  font-size: 23rpx;
  font-weight: 700;
}

.sync-banner-meta {
  margin-top: 4rpx;
  font-size: 21rpx;
  line-height: 1.5;
  opacity: 0.88;
}

.sync-banner-action {
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 760;
}

.settings-panel {
  padding-top: 22rpx;
}

.context-panel {
  padding-top: 22rpx;
}

.context-actions {
  margin-top: 14rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 760;
}

.row-top {
  justify-content: space-between;
}

.status-pill {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid #dbe5ef;
  background: #f3f4f6;
  color: #64748b;
  font-size: 22rpx;
  font-weight: 760;
}

.status-pill.ok {
  background: #dcfce7;
  border-color: #86efac;
  color: #166534;
}

.status-pill.pending {
  background: #fef3c7;
  border-color: #fcd34d;
  color: #92400e;
}

.status-pill.optional {
  background: #eef2f7;
  border-color: #dde6f0;
  color: #64748b;
}

.form-item {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.form-label {
  width: 180rpx;
  font-size: 26rpx;
  color: var(--text-2, #64748b);
}

.form-field {
  flex: 1;
}

.picker {
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--line-soft, #dbe5ef);
  background: var(--surface-2, #edf2f8);
  padding: 0 20rpx;
  font-size: 30rpx;
  color: var(--text-1, #0f172a);
}

.picker.disabled {
  color: #9ca3af;
  background: #f3f4f6;
}

.settings-save {
  margin-top: 20rpx;
}

.player-route-btn {
  margin-top: 12rpx;
}

.referee-current {
  margin-top: 14rpx;
  padding: 18rpx 16rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.referee-current.set {
  background: #fef3c7;
  border: 1rpx solid #fcd34d;
}

.referee-current.unset {
  background: #f3f4f6;
  border: 1rpx solid #e5e7eb;
}

.referee-left {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.referee-name {
  font-size: 32rpx;
  font-weight: 900;
  color: #111827;
  max-width: 420rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.referee-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.referee-btn {
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 18rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.referee-btn.primary {
  background: #16a34a;
  color: #fff;
}

button.referee-btn::after {
  border: none;
}

.players {
  margin-top: 14rpx;
}

.player {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #eef2f7;
}

.player:last-child {
  border-bottom: 0;
}

.player-name {
  font-size: 28rpx;
  color: #111827;
  font-weight: 700;
}

.player-main {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.player-gender-chip {
  min-width: 70rpx;
  text-align: center;
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  background: #eef4fb;
  border: 1rpx solid #dce5ef;
  color: #475569;
  font-size: 22rpx;
  font-weight: 700;
}

.state-title {
  font-size: 32rpx;
  font-weight: 760;
  margin-bottom: 8rpx;
}

.retry-box {
  margin-top: 16rpx;
  padding: 14rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--line-soft, #dbe5ef);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}
