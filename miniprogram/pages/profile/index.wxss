/* ============================================================
   Profile Page — 个人资料编辑
   Design Token: app.wxss design system v2
   ============================================================ */

.profile-page {
  gap: 16rpx;
}

/* --- Form Card --- */
.profile-form-card {
  padding: 24rpx;
}

/* --- Avatar Section (居中) --- */
.profile-avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--neutral-200);
}

.profile-avatar {
  width: 136rpx;
  height: 136rpx;
  border-radius: 999rpx;
  background: var(--neutral-100);
  border: 3rpx solid var(--neutral-200);
}

.avatar-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  justify-content: center;
}

.avatar-tip {
  margin-top: 0;
}

/* --- Quick Fill (更紧凑) --- */
.quick-fill-box {
  margin-top: 24rpx;
  padding: 12rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--neutral-200);
  background: var(--bg-section);
}

.quick-fill-btn {
  margin: 0;
}

/* --- Form Group --- */
.profile-form-group {
  margin-top: 8rpx;
}

.form-item {
  margin-top: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: var(--neutral-500);
  margin-bottom: 12rpx;
  font-weight: 500;
}

/* --- Gender Segment (更清晰) --- */
.gender-segment {
  display: flex;
  gap: 12rpx;
}

.gender-option {
  flex: 1;
  min-height: 80rpx;
  border-radius: 16rpx;
  border: 2rpx solid var(--neutral-200);
  background: var(--neutral-100);
  color: var(--neutral-700);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  transition: transform 120ms ease, filter 120ms ease, border-color 120ms ease, background 120ms ease;
}

.gender-option-press {
  transform: scale(0.986);
  filter: brightness(0.97);
}

.gender-option.selected {
  background: var(--brand-50);
  border-color: var(--brand-500);
  color: var(--brand-700);
  box-shadow: 0 0 0 2rpx rgba(24, 179, 104, 0.1);
}

.gender-check {
  font-size: 22rpx;
  font-weight: 800;
}

.gender-segment-error {
  padding: 6rpx;
  border-radius: 18rpx;
  border: 1rpx solid var(--danger);
  background: #FEF2F2;
}

/* --- Field Errors --- */
.field-error {
  margin-top: 8rpx;
  color: var(--danger);
  font-size: 22rpx;
  font-weight: 500;
  text-align: left;
}

.input-error {
  border-color: var(--danger) !important;
  background: #FEF2F2 !important;
}

/* --- Save Actions (sticky bottom tray) --- */
.profile-actions {
  margin-top: 24rpx;
}
