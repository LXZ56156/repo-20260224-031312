/* preferences — 系统偏好设置 */

.pref-page {
  padding-bottom: 24rpx;
}

/* Chips in preferences — use neutral palette */
.pref-page .chip {
  border: 1rpx solid var(--neutral-200);
  background: var(--neutral-100);
  color: var(--neutral-700);
  font-weight: 500;
}

.pref-page .chip:active {
  transform: scale(0.984);
  filter: brightness(0.96);
}

.pref-page .chip.active {
  border-color: var(--brand-500);
  background: var(--brand-100);
  color: var(--brand-700);
  font-weight: 700;
}

.pref-tip {
  margin-top: 10rpx;
  margin-bottom: 12rpx;
}

/* Switch items */
.switch-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.switch-item .form-label {
  margin-bottom: 0;
  width: auto;
  flex: 1;
}
