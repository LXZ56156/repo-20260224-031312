.pref-page {
  padding-bottom: 24rpx;
}

.form-item {
  margin-top: 14rpx;
}

.form-item:first-child {
  margin-top: 0;
}

.form-label {
  font-size: 27rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.picker {
  background: var(--surface-2, #edf2f8);
  border: 1rpx solid #dfe8f2;
  border-radius: 14rpx;
  padding: 16rpx;
}

.chip {
  border: 1rpx solid #d9e4ef;
  background: #eef4fb;
  color: #334155;
  transition: transform 120ms ease, filter 120ms ease, border-color 120ms ease, background 120ms ease;
}

.chip:active {
  transform: scale(0.984);
  filter: brightness(0.97);
}

.chip.active {
  border-color: #22a763;
  background: #dff4e8;
  color: #0f6a40;
  font-weight: 700;
  box-shadow: inset 0 0 0 2rpx rgba(15, 106, 64, 0.08);
}

.pref-tip {
  margin-top: 10rpx;
  margin-bottom: 12rpx;
}

.pref-row {
  margin-top: 14rpx;
}

.switch-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.switch-item .form-label {
  margin-bottom: 0;
}
