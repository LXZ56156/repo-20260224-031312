/* Schedule 页面样式 — 赛事中控台风 */

.schedule-page {
  padding-top: 24rpx;
}

/* --- Hero 紧凑化 --- */
.hero-kicker {
  font-size: 22rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.78);
  letter-spacing: 0.5rpx;
  text-transform: uppercase;
}

.hero-head {
  gap: 12rpx;
}

.hero-title {
  margin-top: 4rpx;
  font-size: 36rpx;
  font-weight: 820;
  color: #ffffff;
}

.hero-sub {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.88);
}

.hero-stats {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8rpx;
}

.hero-stat {
  padding: 12rpx 14rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
}

.hero-stat-value {
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 780;
}

.hero-stat-label {
  display: block;
  margin-top: 4rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 21rpx;
}

.hero-actions {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.hero-btn {
  width: auto;
  min-width: 200rpx;
  padding: 0 24rpx;
}

.hero-primary {
  min-width: 220rpx;
}

/* --- Round Card --- */
.round-card {
  border-radius: 20rpx;
  padding: 20rpx;
  margin-top: 16rpx;
}

.round-card-current {
  border-color: var(--brand-100);
  border-left: 6rpx solid var(--brand-500);
  box-shadow: 0 8rpx 24rpx rgba(24, 179, 104, 0.1);
}

.round-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 4rpx 4rpx 12rpx;
}

.round-title {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--neutral-950);
}

.count-pill-active {
  background: var(--brand-50);
  border-color: var(--brand-100);
  color: var(--brand-600);
}

/* --- Match Card --- */
.match-card {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  background: var(--neutral-100);
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid var(--neutral-200);
  transition: border-color 120ms ease, background 120ms ease;
}

.match-card:last-child {
  margin-bottom: 0;
}

.match-card-focus {
  border-color: var(--brand-500);
  background: var(--brand-50);
  box-shadow: inset 0 0 0 1rpx rgba(24, 179, 104, 0.12);
}

.match-left {
  flex: 1;
  min-width: 0;
}

.match-title {
  font-weight: 780;
  color: var(--neutral-950);
  font-size: 28rpx;
  margin-bottom: 6rpx;
}

.match-sub {
  color: var(--neutral-700);
  font-size: 26rpx;
  line-height: 36rpx;
  word-break: break-word;
}

.vs {
  color: var(--neutral-300);
  margin: 0 8rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.score {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--brand-700);
}

.focus-pill {
  margin-top: 8rpx;
  display: inline-flex;
  align-items: center;
  min-height: 40rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(24, 179, 104, 0.1);
  color: var(--brand-700);
  font-size: 21rpx;
  font-weight: 700;
}

.match-right {
  display: flex;
  align-items: flex-start;
}

.pill {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  white-space: nowrap;
}

.pill-pending {
  background: rgba(24, 179, 104, 0.1);
  color: var(--brand-700);
}

.pill-finished {
  background: var(--info-100);
  color: var(--info-500);
}

.pill-canceled {
  background: var(--neutral-100);
  color: var(--neutral-500);
}

.team-meta {
  margin-top: 4rpx;
}

.rest {
  padding: 4rpx 8rpx 0;
}

/* --- State Cards --- */
.state-card {
  margin-top: 16rpx;
}

.state-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  color: var(--neutral-700);
}

.state-link {
  margin-top: 12rpx;
  display: inline-flex;
  align-items: center;
  min-height: 48rpx;
  padding: 0 12rpx;
  color: var(--brand-600);
  font-size: 24rpx;
  font-weight: 700;
}

/* --- Skeleton 拟真化 --- */
.skeleton-match-block {
  margin-top: 16rpx;
  padding: 14rpx;
  border-radius: 16rpx;
  background: var(--neutral-100);
  border: 1rpx solid var(--neutral-200);
}
