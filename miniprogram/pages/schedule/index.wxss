.round-card{background:#fff;border-radius:24rpx;box-shadow:0 10rpx 30rpx rgba(0,0,0,0.06);padding:20rpx;margin-bottom:20rpx;}
.round-header{display:flex;align-items:flex-end;justify-content:space-between;padding:6rpx 6rpx 14rpx 6rpx;}
.round-title{font-size:34rpx;font-weight:800;color:#0f172a;}

.match-card{display:flex;justify-content:space-between;gap:16rpx;background:#f8fafc;border-radius:20rpx;padding:16rpx 16rpx;margin-bottom:14rpx;border:1rpx solid rgba(0,0,0,0.03);}
.match-left{flex:1;min-width:0;}
.match-title{font-weight:800;color:#0f172a;font-size:28rpx;margin-bottom:8rpx;}
.match-sub{color:#334155;font-size:26rpx;line-height:36rpx;word-break:break-word;}
.vs{color:#94a3b8;margin:0 10rpx;font-size:24rpx;}
.score{margin-top:8rpx;font-size:24rpx;color:#0f766e;}
.match-right{display:flex;align-items:flex-start;}
.pill{padding:10rpx 14rpx;border-radius:999rpx;font-size:22rpx;font-weight:700;white-space:nowrap;}
.pill-pending{background:rgba(16,185,129,0.12);color:#065f46;}
.pill-finished{background:rgba(59,130,246,0.12);color:#1d4ed8;}

.rest{padding:4rpx 8rpx 0 8rpx;}
