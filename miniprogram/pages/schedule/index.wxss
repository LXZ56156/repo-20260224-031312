@import "../../styles/matchPrimaryNav.wxss";

.schedule-page {
  padding-top: 24rpx;
}

.hero-kicker {
  font-size: 22rpx;
  font-weight: 760;
  color: rgba(255, 255, 255, 0.8);
}

.hero-head {
  gap: 14rpx;
}

.hero-title {
  margin-top: 8rpx;
  font-size: 40rpx;
  font-weight: 840;
  color: #ffffff;
}

.hero-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.88);
}

.sync-banner {
  margin-bottom: 12rpx;
  padding: 12rpx 16rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.sync-warning {
  background: #fef3c7;
  border: 1rpx solid #fcd34d;
  color: #92400e;
}

.sync-info {
  background: #eff6ff;
  border: 1rpx solid #bfdbfe;
  color: #1d4ed8;
}

.sync-neutral {
  background: #f8fafc;
  border: 1rpx solid #dbe5ef;
  color: #334155;
}

.sync-banner-main {
  flex: 1;
  min-width: 0;
}

.sync-banner-text {
  font-size: 23rpx;
  font-weight: 700;
}

.sync-banner-meta {
  margin-top: 4rpx;
  font-size: 21rpx;
  opacity: 0.88;
  line-height: 1.5;
}

.sync-banner-action {
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 760;
}

.state-card {
  margin-top: 18rpx;
}

.state-title {
  font-size: 32rpx;
  font-weight: 760;
  margin-bottom: 8rpx;
}

.state-link {
  margin-top: 12rpx;
  display: inline-flex;
  align-items: center;
  min-height: 48rpx;
  padding: 0 12rpx;
  color: var(--brand-strong, #14804b);
  font-size: 24rpx;
  font-weight: 760;
}

.round-card {
  border-radius: 24rpx;
  padding: 20rpx;
  margin-top: 18rpx;
}

.round-card-current {
  border-color: #86efac;
  box-shadow: 0 10rpx 22rpx rgba(20, 128, 75, 0.08);
}

.round-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 6rpx 6rpx 14rpx;
}

.round-title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-1, #0f172a);
}

.match-card {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  background: var(--surface-2, #edf2f8);
  border-radius: 20rpx;
  padding: 16rpx;
  margin-bottom: 14rpx;
  border: 1rpx solid var(--line-soft, #dbe5ef);
}

.match-card-focus {
  border-color: #22c55e;
  background: linear-gradient(180deg, #f3fbf5 0%, #edf9f0 100%);
}

.match-left {
  flex: 1;
  min-width: 0;
}

.match-title {
  font-weight: 800;
  color: var(--text-1, #0f172a);
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.match-sub {
  color: #334155;
  font-size: 26rpx;
  line-height: 36rpx;
  word-break: break-word;
}

.vs {
  color: #94a3b8;
  margin: 0 10rpx;
  font-size: 24rpx;
}

.score {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #0f766e;
}

.focus-pill {
  margin-top: 8rpx;
  display: inline-flex;
  align-items: center;
  min-height: 42rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(34, 197, 94, 0.14);
  color: #166534;
  font-size: 21rpx;
  font-weight: 760;
}

.match-right {
  display: flex;
  align-items: flex-start;
}

.pill {
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  white-space: nowrap;
}

.pill-pending {
  background: rgba(16, 185, 129, 0.12);
  color: #065f46;
}

.pill-finished {
  background: rgba(59, 130, 246, 0.12);
  color: #1d4ed8;
}

.pill-canceled {
  background: rgba(148, 163, 184, 0.2);
  color: #475569;
}

.team-meta {
  margin-top: 6rpx;
}

.rest {
  padding: 4rpx 8rpx 0;
}

.hero-actions {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.hero-btn {
  width: auto;
  min-width: 220rpx;
  padding: 0 24rpx;
}

.hero-primary {
  min-width: 240rpx;
}

.hero-stats {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.hero-stat {
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
}

.hero-stat-value {
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 760;
}

.hero-stat-label {
  display: block;
  margin-top: 6rpx;
  color: rgba(255, 255, 255, 0.8);
  font-size: 21rpx;
}
