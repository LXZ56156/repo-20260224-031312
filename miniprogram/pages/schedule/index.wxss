.schedule-page {
  padding-top: 24rpx;
}

.stale-banner {
  margin-bottom: 12rpx;
  padding: 10rpx 14rpx;
  border-radius: 14rpx;
  background: #eff6ff;
  border: 1rpx solid #bfdbfe;
  color: #1d4ed8;
  font-size: 23rpx;
}

.state-card {
  margin-top: 18rpx;
}

.state-title {
  font-size: 32rpx;
  font-weight: 760;
  margin-bottom: 8rpx;
}

.state-link {
  margin-top: 12rpx;
  display: inline-flex;
  align-items: center;
  min-height: 48rpx;
  padding: 0 12rpx;
  color: var(--brand-strong, #14804b);
  font-size: 24rpx;
  font-weight: 760;
}

.round-card {
  border-radius: 24rpx;
  padding: 20rpx;
  margin-top: 18rpx;
}

.round-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 6rpx 6rpx 14rpx;
}

.round-title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-1, #0f172a);
}

.match-card {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  background: var(--surface-2, #edf2f8);
  border-radius: 20rpx;
  padding: 16rpx;
  margin-bottom: 14rpx;
  border: 1rpx solid var(--line-soft, #dbe5ef);
}

.match-left {
  flex: 1;
  min-width: 0;
}

.match-title {
  font-weight: 800;
  color: var(--text-1, #0f172a);
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.match-sub {
  color: #334155;
  font-size: 26rpx;
  line-height: 36rpx;
  word-break: break-word;
}

.vs {
  color: #94a3b8;
  margin: 0 10rpx;
  font-size: 24rpx;
}

.score {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #0f766e;
}

.match-right {
  display: flex;
  align-items: flex-start;
}

.pill {
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  white-space: nowrap;
}

.pill-pending {
  background: rgba(16, 185, 129, 0.12);
  color: #065f46;
}

.pill-finished {
  background: rgba(59, 130, 246, 0.12);
  color: #1d4ed8;
}

.pill-canceled {
  background: rgba(148, 163, 184, 0.2);
  color: #475569;
}

.team-meta {
  margin-top: 6rpx;
}

.rest {
  padding: 4rpx 8rpx 0;
}

.hero-actions {
  margin-top: 14rpx;
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.hero-btn {
  width: auto;
  min-width: 220rpx;
  padding: 0 24rpx;
}
