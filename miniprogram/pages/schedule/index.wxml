<view class="container safe-bottom schedule-page" wx:if="{{tournament}}">
  <view class="match-primary-nav">
    <view
      class="match-primary-nav-item {{item.active ? 'active' : ''}}"
      wx:for="{{primaryNavItems}}"
      wx:key="key"
      data-key="{{item.key}}"
      bindtap="onPrimaryNavTap"
    >
      {{item.text}}
    </view>
  </view>

  <view class="sync-banner sync-{{syncStatusTone}}" wx:if="{{syncStatusVisible}}">
    <view class="sync-banner-main">
      <view class="sync-banner-text">{{syncStatusText}}</view>
      <view class="sync-banner-meta" wx:if="{{syncStatusMeta}}">{{syncStatusMeta}}</view>
    </view>
    <text class="sync-banner-action" bindtap="onRetry">{{syncStatusActionText}}</text>
  </view>
  <view class="hero">
    <view class="row hero-head">
      <view class="flex-1 minw0">
        <view class="hero-kicker">当前对阵</view>
        <view class="hero-title ellipsis">{{tournament.name}}</view>
        <view class="hero-sub">{{heroSummaryText}}</view>
      </view>
      <view class="tag {{statusClass}}">{{statusText}}</view>
    </view>
    <view class="hero-stats">
      <view class="hero-stat">
        <view class="hero-stat-value">{{heroRoundText}}</view>
        <view class="hero-stat-label">轮次</view>
      </view>
      <view class="hero-stat">
        <view class="hero-stat-value">{{heroMatchText}}</view>
        <view class="hero-stat-label">进度</view>
      </view>
      <view class="hero-stat">
        <view class="hero-stat-value">{{heroPendingText}}</view>
        <view class="hero-stat-label">状态</view>
      </view>
    </view>
    <view class="hero-actions" wx:if="{{nextActionText}}">
      <button class="btn btn-primary btn-sm hero-btn hero-primary" wx:if="{{nextActionText}}" bindtap="onHeroActionTap">{{nextActionText}}</button>
    </view>
  </view>

  <view class="card panel panel-soft state-card" wx:if="{{!roundsUi.length}}">
    <view class="state-title">还没有对阵</view>
  </view>

  <view class="round-card panel {{item.isCurrentRound ? 'round-card-current' : ''}}" wx:for="{{roundsUi}}" wx:key="roundIndex">
    <view class="round-header">
      <view class="round-title">第{{item.roundIndex + 1}}轮</view>
      <text class="count-pill" wx:if="{{item.isCurrentRound}}">当前待录分轮次</text>
      <text class="muted small" wx:else>{{item.matchesUi.length}} 场</text>
    </view>

    <view class="match-card {{m.isFirstPending ? 'match-card-focus' : ''}}" wx:for="{{item.matchesUi}}" wx:for-item="m" wx:key="key" data-round="{{m.roundIndex}}" data-match="{{m.matchIndex}}" data-status="{{m.status}}" bindtap="openMatch">
      <view class="match-left">
        <view class="match-title">{{m.title}}</view>
        <view class="match-sub">{{m.left}} <text class="vs">vs</text> {{m.right}}</view>
        <view class="muted tiny team-meta" wx:if="{{m.leftMeta}}">{{m.leftMeta}}</view>
        <view class="muted tiny team-meta" wx:if="{{m.rightMeta}}">{{m.rightMeta}}</view>
        <view class="focus-pill" wx:if="{{m.focusBadgeText}}">{{m.focusBadgeText}}</view>
        <view class="score" wx:if="{{m.scoreText}}">比分：{{m.scoreText}}</view>
        <view class="score" wx:if="{{m.scorerText}}">{{m.scorerText}}</view>
      </view>
      <view class="match-right">
        <view class="pill {{m.statusClass}}">{{m.statusText}}</view>
      </view>
    </view>

    <view class="rest" wx:if="{{item.restText}}">
      <text class="muted small">{{item.restText}}</text>
    </view>
  </view>
</view>

<view class="container safe-bottom schedule-page" wx:elif="{{loadError}}">
  <view class="card panel state-card">
    <view class="state-title">加载失败</view>
    <view class="muted">请检查网络后重试。</view>
    <button class="btn btn-subtle" bindtap="onRetry">重新加载</button>
  </view>
</view>

<view class="container safe-bottom schedule-page" wx:else>
  <view class="card panel state-card">
    <view class="state-title">加载中...</view>
    <view class="muted">正在同步最新对阵。</view>
  </view>
</view>
