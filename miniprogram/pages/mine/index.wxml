<view class="container safe-bottom mine-page">
  <view class="hero mine-hero">
    <view class="row mine-dashboard">
      <image class="profile-avatar" src="{{avatar}}" mode="aspectFill"></image>
      <view class="flex-1 minw0 profile-main">
        <view class="mine-nickname ellipsis">{{nickname}}</view>
        <view class="mine-quick-links">
          <text class="mine-quick-link" bindtap="goProfile">编辑资料</text>
          <text class="mine-quick-divider">·</text>
          <text class="mine-quick-link" bindtap="goSettings">设置</text>
        </view>
      </view>
      <view class="mine-action-primary" bindtap="goHome">查看比赛</view>
    </view>
  </view>

  <view class="card panel section-card">
    <view class="section-head">
      <view class="section-title">我的战绩</view>
      <text class="count-pill">本地已完成</text>
    </view>
    <view class="stats-grid" wx:if="{{!noPerformanceData}}">
      <view class="stats-item">
        <view class="stats-label">已完成参赛</view>
        <view class="stats-value text-metric">{{tournamentsCompleted}}</view>
      </view>
      <view class="stats-item">
        <view class="stats-label">参赛场次</view>
        <view class="stats-value text-metric">{{matchesPlayed}}</view>
      </view>
      <view class="stats-item">
        <view class="stats-label">胜场</view>
        <view class="stats-value text-metric">{{wins}}</view>
      </view>
      <view class="stats-item">
        <view class="stats-label">胜率</view>
        <view class="stats-value text-metric">{{winRateText}}</view>
      </view>
    </view>
    <view class="stats-foot muted" wx:if="{{!noPerformanceData}}">
      净胜分 {{pointDiffText}}<text wx:if="{{last10Text}}"> · {{last10Text}}</text>
    </view>
    <view class="state-empty" wx:if="{{noPerformanceData}}">
      <view class="state-empty-title">暂无战绩</view>
      <view class="state-empty-desc">还没有已完成的参赛记录</view>
      <view class="state-empty-action">
        <button class="btn btn-sm btn-secondary btn-inline" bindtap="goLaunch">发起或加入比赛</button>
      </view>
    </view>
  </view>

  <view class="card panel section-card">
    <view class="section-head">
      <view class="section-title">我的服务</view>
    </view>
    <view class="service-grid">
      <view class="service-btn" bindtap="goMyTournaments">
        <view class="service-title">我的比赛</view>
        <view class="service-desc">查看赛事</view>
      </view>
      <view class="service-btn" bindtap="onFeedback">
        <view class="service-title">意见反馈</view>
        <view class="service-desc">提交建议</view>
      </view>
    </view>
  </view>
</view>
