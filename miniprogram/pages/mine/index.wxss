/* ============================================================
   Mine Page — 个人仪表盘
   Design Token: app.wxss design system v2
   ============================================================ */

.mine-page {
  padding-bottom: 32rpx;
}

/* --- Hero / Dashboard --- */
.mine-hero {
  padding: 28rpx 24rpx;
  background:
    radial-gradient(ellipse at 85% 15%, rgba(255, 255, 255, 0.14) 0%, transparent 50%),
    linear-gradient(135deg, var(--brand-700) 0%, var(--brand-500) 55%, #2DD47A 100%);
}

.mine-dashboard {
  gap: 16rpx;
}

.profile-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 999rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.35);
  background: rgba(255, 255, 255, 0.2);
  flex-shrink: 0;
}

.profile-main {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
  min-height: 88rpx;
}

.mine-nickname {
  font-size: 34rpx;
  font-weight: 780;
  line-height: 1.25;
  color: #ffffff;
}

.mine-quick-links {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.mine-quick-link {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.88);
  line-height: 1.3;
}

.mine-quick-link:active {
  opacity: 0.7;
}

.mine-quick-divider {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

.mine-action-primary {
  flex-shrink: 0;
  height: 64rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  color: var(--brand-700);
  font-size: 25rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 120ms ease, filter 120ms ease;
}

.mine-action-primary:active {
  transform: scale(0.985);
  filter: brightness(0.97);
}

/* --- Section Card --- */
.section-card {
  margin-top: 16rpx;
  padding: 24rpx;
}

/* --- Stats Grid --- */
.stats-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.stats-item {
  background: var(--bg-section);
  border: 1rpx solid var(--neutral-200);
  border-radius: 16rpx;
  padding: 16rpx;
}

.stats-label {
  color: var(--neutral-500);
  font-size: 24rpx;
  line-height: 1.3;
}

.stats-value {
  margin-top: 8rpx;
}

/* text-metric 类由 app.wxss 全局提供: 36rpx / font-weight 800 */

.stats-foot {
  margin-top: 16rpx;
  font-size: 24rpx;
}

/* --- Empty State (使用全局 state-empty) --- */
.state-empty-action {
  margin-top: 8rpx;
}

/* --- Service Grid --- */
.service-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.service-btn {
  border: 1rpx solid var(--neutral-200);
  border-radius: 16rpx;
  background: var(--bg-section);
  padding: 16rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  min-height: 104rpx;
  transition: transform 120ms ease, filter 120ms ease;
}

.service-btn:active {
  transform: scale(0.985);
  filter: brightness(0.97);
}

.service-title {
  color: var(--neutral-950);
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.2;
}

.service-desc {
  margin-top: 6rpx;
  color: var(--neutral-500);
  font-size: 22rpx;
  line-height: 1.2;
}
