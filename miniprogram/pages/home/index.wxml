<view class="page home-page" wx:if="{{!loadError}}">
  <!-- sync-banner: hidden 替代 wx:if，消除 layout shift -->
  <view class="sync-banner sync-{{syncStatusTone}}" hidden="{{!syncStatusVisible}}">
    <view class="sync-banner-main">
      <view class="sync-banner-text">{{syncStatusText}}</view>
      <view class="sync-banner-meta" wx:if="{{syncStatusMeta}}">{{syncStatusMeta}}</view>
    </view>
    <text class="sync-banner-action" bindtap="onRetry">{{syncStatusActionText}}</text>
  </view>

  <!-- Hero: 紧凑工作台卡片 -->
  <view class="hero-card hero reveal reveal-1" wx:if="{{showHeroCard}}">
    <view class="hero-grid">
      <view class="hero-main">
        <view class="hero-env-badge" wx:if="{{showEnvBadge}}">{{envBadgeLabel}}</view>
        <view class="h-title">{{heroCard.title}}</view>
        <view class="hero-task-strip {{heroCard.empty ? 'hero-task-empty' : ''}}">
          <view class="hero-task-label">{{heroCard.label}}</view>
          <view class="hero-task-name ellipsis" wx:if="{{heroCard.name}}">{{heroCard.name}}</view>
          <view class="hero-task-meta" wx:if="{{heroCard.meta}}">{{heroCard.meta}}</view>
          <view class="hero-task-detail" wx:if="{{heroCard.detail}}">{{heroCard.detail}}</view>
          <view class="hero-progress-wrap" wx:if="{{heroCard.progress >= 0}}">
            <view class="hero-progress-bar">
              <view class="hero-progress-fill" style="width: {{heroCard.progress}}%;"></view>
            </view>
            <text class="hero-progress-text">{{heroCard.progress}}%</text>
          </view>
          <button class="btn btn-primary btn-sm hero-task-btn"
            bindtap="onHeroPrimaryTap"
            data-action="{{heroCard.actionTarget}}"
            data-id="{{heroCard.actionId}}"
            data-round="{{heroCard.actionRound}}"
            data-match="{{heroCard.actionMatch}}">
            {{heroCard.actionText}}
          </button>
        </view>
      </view>
    </view>
  </view>

  <!-- 赛事列表 section -->
  <view class="section reveal reveal-2">
    <view class="section-head">
      <view class="section-title">我的赛事</view>
      <text class="count-pill">{{visibleCount}} 个</text>
    </view>
    <view class="toolbar-row" wx:if="{{items.length>1}}">
      <view class="sort-row">
        <text class="sort-label">排序</text>
        <text class="sort-chip {{sortMode==='updated' ? 'active' : ''}}" data-mode="updated" bindtap="onChangeSortMode">最近更新</text>
        <text class="sort-chip {{sortMode==='players' ? 'active' : ''}}" data-mode="players" bindtap="onChangeSortMode">按人数</text>
        <text class="sort-chip {{sortMode==='status' ? 'active' : ''}}" data-mode="status" bindtap="onChangeSortMode">按状态</text>
      </view>
      <view class="filter-row">
        <text class="filter-chip {{filterStatus==='all' ? 'active' : ''}}" data-status="all" bindtap="onChangeFilterStatus">全部 {{items.length}}</text>
        <text class="filter-chip {{filterStatus==='running' ? 'active' : ''}}" data-status="running" bindtap="onChangeFilterStatus">进行中 {{statusCountRunning}}</text>
        <text class="filter-chip {{filterStatus==='draft' ? 'active' : ''}}" data-status="draft" bindtap="onChangeFilterStatus">草稿 {{statusCountDraft}}</text>
        <text class="filter-chip {{filterStatus==='finished' ? 'active' : ''}}" data-status="finished" bindtap="onChangeFilterStatus">已结束 {{statusCountFinished}}</text>
      </view>
    </view>

    <!-- skeleton: 更拟真的卡片骨架 -->
    <view wx:if="{{loading && !items.length}}" class="skeleton-list">
      <view class="skeleton-card-wrap reveal reveal-1">
        <view class="skeleton-card">
          <view class="skeleton-row" style="margin-bottom: 16rpx;">
            <view class="skeleton-bone skeleton-line skeleton-line-medium" style="margin-bottom: 0;"></view>
            <view class="skeleton-bone skeleton-badge"></view>
          </view>
          <view class="skeleton-row" style="gap: 10rpx;">
            <view class="skeleton-bone skeleton-pill"></view>
            <view class="skeleton-bone skeleton-pill"></view>
            <view class="skeleton-bone skeleton-pill"></view>
          </view>
          <view class="skeleton-bone skeleton-line skeleton-line-short" style="margin-top: 14rpx;"></view>
        </view>
      </view>
      <view class="skeleton-card-wrap reveal reveal-2">
        <view class="skeleton-card">
          <view class="skeleton-row" style="margin-bottom: 16rpx;">
            <view class="skeleton-bone skeleton-line skeleton-line-long" style="margin-bottom: 0;"></view>
            <view class="skeleton-bone skeleton-badge"></view>
          </view>
          <view class="skeleton-row" style="gap: 10rpx;">
            <view class="skeleton-bone skeleton-pill"></view>
            <view class="skeleton-bone skeleton-pill"></view>
          </view>
          <view class="skeleton-bone skeleton-line skeleton-line-short" style="margin-top: 14rpx;"></view>
        </view>
      </view>
      <view class="skeleton-card-wrap reveal reveal-3">
        <view class="skeleton-card">
          <view class="skeleton-row" style="margin-bottom: 16rpx;">
            <view class="skeleton-bone skeleton-line skeleton-line-long" style="margin-bottom: 0;"></view>
            <view class="skeleton-bone skeleton-badge"></view>
          </view>
          <view class="skeleton-row" style="gap: 10rpx;">
            <view class="skeleton-bone skeleton-pill"></view>
            <view class="skeleton-bone skeleton-pill"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 赛事列表 -->
    <block wx:if="{{visibleCount>0}}">
      <block wx:for="{{items}}" wx:key="_id">
        <block wx:if="{{filterStatus==='all' || item.status===filterStatus}}">
          <view class="swipe-row card" data-idx="{{index}}" data-id="{{item._id}}"
            bindtouchstart="onTouchStart" bindtouchmove="onTouchMove" bindtouchend="onTouchEnd">
            <view class="swipe-actions">
              <view class="del-btn" catchtap="onDeleteTap" data-id="{{item._id}}">删除</view>
            </view>
            <view class="swipe-content tone-{{item.status}}" style="transform: translateX({{item._offset}}rpx);" catchtap="onCardTap" data-id="{{item._id}}" data-idx="{{index}}">
              <view class="t-card">
                <view class="row t-top">
                  <view class="flex-1 minw0">
                    <view class="t-title ellipsis">{{item.name || '未命名赛事'}}</view>
                  </view>
                  <view class="badge {{item.statusClass}}">{{item.statusLabel}}</view>
                </view>
                <view class="t-stats">
                  <text class="pill">{{item.modeLabel}}</text>
                  <text class="pill">{{item.playersCount}}人</text>
                  <text class="pill">{{item.matchProgressText}}</text>
                </view>
                <view class="t-time muted small">更新 {{item.updatedAtText}}</view>
                <view class="t-actions" wx:if="{{item.status!=='missing'}}">
                  <text class="t-quick-action" catchtap="onQuickActionTap" data-id="{{item._id}}" data-status="{{item.status}}" wx:if="{{item.status==='finished'}}">查看复盘</text>
                  <text class="t-copy-link" catchtap="onCloneTap" data-id="{{item._id}}" wx:if="{{item.status==='finished'}}">再办一场</text>
                  <text class="t-quick-action" catchtap="onQuickActionTap" data-id="{{item._id}}" data-status="{{item.status}}" wx:elif="{{item.status==='running'}}">查看对阵</text>
                </view>
              </view>
            </view>
          </view>
        </block>
      </block>
    </block>

    <!-- 空态: 统一 state-empty 结构 -->
    <view wx:else class="state-empty">
      <view class="state-empty-icon">📋</view>
      <view class="state-empty-title">当前筛选下还没有比赛</view>
      <view class="state-empty-desc">创建新赛事或切换筛选条件查看更多</view>
    </view>
  </view>

  <view class="card panel-soft profile-nudge reveal reveal-3" wx:if="{{showProfileNudge}}">
    <view class="section-head">
      <view class="section-title">先补资料</view>
      <text class="count-pill">推荐</text>
    </view>
    <view class="profile-nudge-actions">
      <button class="btn btn-subtle btn-sm" bindtap="goProfileFromNudge">去完善</button>
      <text class="profile-nudge-later" bindtap="dismissProfileNudge">稍后</text>
    </view>
  </view>

  <view class="onboarding card panel reveal reveal-4" wx:if="{{showOnboarding}}">
    <view class="section-head">
      <view class="section-title">三步开赛</view>
      <text class="count-pill">新手引导</text>
    </view>
    <view class="guide-step"><text class="guide-index">1</text><text class="guide-text">创建并设参数</text></view>
    <view class="guide-step"><text class="guide-index">2</text><text class="guide-text">分享邀请或导入名单</text></view>
    <view class="guide-step"><text class="guide-index">3</text><text class="guide-text">开赛后录分</text></view>
    <text class="onboarding-later" bindtap="dismissOnboarding">稍后再看</text>
  </view>

  <view class="card panel-soft ad-breakpoint reveal reveal-5" wx:if="{{showHomeAdSlot}}">
    <view class="ad-badge">广告</view>
  </view>

  <view class="retry-box panel-soft" wx:if="{{canRetryAction}}">
    <view class="muted small">{{lastFailedActionText}}</view>
    <button class="btn btn-subtle btn-sm" bindtap="retryLastAction">重试上次操作</button>
  </view>
</view>

<!-- 错误态: 统一 state-error 结构 -->
<view class="container safe-bottom" wx:else>
  <view class="state-error">
    <view class="state-error-icon">⚠️</view>
    <view class="state-error-title">加载失败</view>
    <view class="state-error-desc">请检查网络后重试</view>
    <view class="state-error-actions">
      <button class="btn btn-primary" bindtap="onRetry">重新加载</button>
    </view>
  </view>
</view>
