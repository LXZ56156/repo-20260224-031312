.home-page {
  padding: 26rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 26rpx);
}

.offline-banner {
  margin-bottom: 12rpx;
  padding: 10rpx 14rpx;
  border-radius: 14rpx;
  background: #fef3c7;
  border: 1rpx solid #fcd34d;
  color: #92400e;
  font-size: 23rpx;
}

.onboarding {
  margin-top: 0;
}

.profile-nudge {
  margin-top: 0;
  border-radius: 20rpx;
  border: 1rpx solid #d7e6f4;
}

.profile-nudge-actions {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.profile-nudge-later {
  font-size: 24rpx;
  color: #64748b;
}

.guide-step {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.guide-index {
  width: 36rpx;
  height: 36rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #dcfce7;
  color: #166534;
  font-size: 22rpx;
  font-weight: 760;
}

.guide-text {
  flex: 1;
  min-width: 0;
  font-size: 25rpx;
  color: var(--text-1, #0f172a);
}

.onboarding-tip {
  margin-top: 12rpx;
}

.onboarding-later {
  margin-top: 12rpx;
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: var(--text-2, #64748b);
}

.hero-card {
  margin-top: 0;
  padding: 0;
  border-radius: 30rpx;
  overflow: hidden;
  background:
    radial-gradient(circle at 86% 18%, rgba(255, 255, 255, 0.38) 0%, rgba(255, 255, 255, 0) 38%),
    linear-gradient(136deg, #0e9a56 0%, #1db063 56%, #43c67d 100%);
  color: #ffffff;
}

.continue-card {
  margin-top: 0;
  border-radius: 24rpx;
}

.continue-name {
  font-size: 30rpx;
  font-weight: 780;
  color: #0f172a;
}

.continue-meta {
  margin-top: 6rpx;
}

.continue-btn {
  margin-top: 12rpx;
  width: auto;
  min-width: 180rpx;
}

.hero-grid {
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 0;
}

.hero-main {
  flex: 1;
  min-width: 0;
}

.hero-env-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  padding: 5rpx 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  background: rgba(15, 23, 42, 0.18);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 760;
  letter-spacing: 1rpx;
}

.h-title {
  margin-top: 0;
  font-size: 50rpx;
  font-weight: 820;
  line-height: 1.2;
  letter-spacing: 0.5rpx;
}

.h-desc {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.45;
  color: rgba(255, 255, 255, 0.88);
}

.sort-row {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.sort-label {
  font-size: 22rpx;
  color: #64748b;
}

.sort-chip {
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid #dce5ef;
  background: #f8fbff;
  color: #334155;
  font-size: 22rpx;
  font-weight: 700;
}

.sort-chip.active {
  background: #e8f6ee;
  border-color: #b7e0c6;
  color: #0f7a46;
}

.sort-note {
  margin-top: 8rpx;
}

.filter-row {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.filter-chip {
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid #dce5ef;
  background: #f8fbff;
  color: #334155;
  font-size: 22rpx;
  font-weight: 700;
}

.filter-chip.active {
  background: #dcfce7;
  border-color: #86efac;
  color: #166534;
}

.section {
  margin-top: 18rpx;
}

.ad-breakpoint {
  margin-top: 18rpx;
  padding: 16rpx;
  border-radius: 18rpx;
  border: 1rpx dashed #cfe0ef;
  background: #f8fbff;
}

.ad-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 3rpx 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid #dbe5ef;
  background: #ffffff;
  color: #64748b;
  font-size: 21rpx;
  margin-bottom: 8rpx;
}

.section-head {
  margin: 2rpx 4rpx 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 760;
  color: var(--text-1, #0f172a);
}

.swipe-row {
  position: relative;
  overflow: hidden;
  border-radius: 22rpx;
  margin-top: 12rpx;
  border: 1rpx solid var(--line-soft, #dbe5ef);
  box-shadow: 0 8rpx 18rpx rgba(15, 23, 42, 0.08);
}

.swipe-row.card {
  padding: 0;
  margin-top: 12rpx;
}

.swipe-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 160rpx;
  display: flex;
  justify-content: flex-end;
  z-index: 0;
}

.del-btn {
  width: 160rpx;
  background: linear-gradient(145deg, #ef5350, #e5484d);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  font-size: 28rpx;
}

.swipe-content {
  position: relative;
  z-index: 1;
  width: 100%;
  background: var(--surface-1, #ffffff);
  will-change: transform;
}

.swipe-content.tone-running { border-left: 8rpx solid #22a664; }
.swipe-content.tone-draft { border-left: 8rpx solid #8aa0b5; }
.swipe-content.tone-finished { border-left: 8rpx solid #e07a5f; }
.swipe-content.tone-missing,
.swipe-content.tone-unknown { border-left: 8rpx solid #9ca3af; }

.t-card {
  padding: 18rpx 18rpx 18rpx 20rpx;
}

.t-top {
  align-items: flex-start;
}

.t-title {
  font-size: 30rpx;
  font-weight: 760;
  color: var(--text-1, #0f172a);
}

.t-stats {
  margin-top: 12rpx;
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.pill {
  background: var(--surface-2, #edf2f8);
  border: 1rpx solid #dce5ef;
  color: #0f172a;
  padding: 7rpx 13rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.t-time {
  margin-top: 12rpx;
  color: var(--text-2, #64748b);
}

.t-actions {
  margin-top: 12rpx;
  display: flex;
  justify-content: flex-end;
}

.t-copy-link {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #ecf7f0;
  border: 1rpx solid #cfe6d7;
  color: #0f7a46;
  font-size: 23rpx;
  font-weight: 760;
}

.empty {
  margin-top: 12rpx;
  padding: 28rpx 18rpx;
  border-radius: 18rpx;
  color: var(--text-2, #64748b);
  font-size: 25rpx;
  border: 1rpx dashed #dbe5ef;
}

.section-empty {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  align-items: flex-start;
}

.empty-text {
  color: var(--text-2, #64748b);
}

.empty-link {
  margin-top: 8rpx;
  color: #0f7a46;
  font-size: 26rpx;
  font-weight: 700;
}

.retry-box {
  margin-top: 16rpx;
  padding: 14rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--line-soft, #dbe5ef);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

@media (max-width: 360px) {
  .hero-grid {
    flex-direction: column;
  }

  .profile-nudge-actions {
    flex-direction: column;
    align-items: stretch;
  }
}
