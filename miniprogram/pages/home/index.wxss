.page {
  padding: 28rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 28rpx);
}

.hero-card {
  padding: 26rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #16a34a, #22c55e);
  color: #ffffff;
  box-shadow: 0 20rpx 40rpx rgba(34, 197, 94, 0.22);
  overflow: hidden;
}

.hero-row { display: flex; align-items: center; gap: 18rpx; }
.hero-left { flex: 1; min-width: 0; }
.btn-create {
  width: auto;
  padding: 0 28rpx;
  height: 78rpx;
  line-height: 78rpx;
  border-radius: 18rpx;
  font-size: 30rpx;
  background: rgba(255, 255, 255, 0.95);
  color: #166534;
  box-shadow: 0 10rpx 18rpx rgba(0, 0, 0, 0.12);
}
.h-title { font-size: 42rpx; font-weight: 900; letter-spacing: 1rpx; }
.h-sub { margin-top: 8rpx; font-size: 26rpx; color: rgba(255,255,255,0.92); line-height: 1.4; }

.h-badges { margin-top: 14rpx; display: flex; flex-wrap: wrap; gap: 10rpx; }
.h-badge {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  font-size: 22rpx;
  color: rgba(255,255,255,0.95);
}

.section { margin-top: 18rpx; }
.section-hd { display:flex; align-items:center; justify-content:space-between; margin: 8rpx 4rpx; }
.section-title { font-size: 30rpx; font-weight: 700; }
.count { font-size: 24rpx; color: #6B7280; }

.t-card { padding: 16rpx; }
.t-title { font-size: 30rpx; font-weight: 700; }
.t-meta { margin-top: 6rpx; font-size: 24rpx; color: #6B7280; }
.t-stats { margin-top: 12rpx; display:flex; gap: 10rpx; flex-wrap: wrap; }
.pill { background: #F3F4F6; color: #111827; padding: 6rpx 12rpx; border-radius: 999rpx; font-size: 22rpx; }
.actions { margin-top: 12rpx; display:flex; justify-content:flex-end; }
.btn-ghost { border: 1rpx solid #E5E7EB; background: #FFFFFF; color:#374151; border-radius: 14rpx; padding: 10rpx 16rpx; font-size: 24rpx; }

.empty { padding: 28rpx 10rpx; color: #6B7280; font-size: 26rpx; text-align: left; }

/* ===== Swipe delete ===== */
.swipe-row {
  position: relative;
  overflow: hidden;
  border-radius: 24rpx;
  margin-top: 12rpx;
}

/* 覆盖全局 .card 的 padding，避免未滑动时右侧按钮露出 */
.swipe-row.card {
  padding: 0;
}

.swipe-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 160rpx;
  display: flex;
  align-items: stretch;
  justify-content: flex-end;
  z-index: 0;
}

.del-btn {
  width: 160rpx;
  background: #ef4444;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  font-size: 28rpx;
}

.swipe-content {
  will-change: transform;
  position: relative;
  z-index: 1;
  width: 100%;
  background: #ffffff;
}

.t-card {
  margin-top: 0;
}

.t-time { margin-top: 10rpx; }