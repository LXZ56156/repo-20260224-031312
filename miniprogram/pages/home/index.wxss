/* ============================================================
   HOME — 赛事工作台首页
   ============================================================ */

.home-page {
  padding: 20rpx 24rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 24rpx);
}

/* sync-banner: 继承全局 app.wxss 基类, 仅覆盖页面间距 */
.home-page > .sync-banner {
  margin-bottom: 12rpx;
}

/* --- Hero 紧凑工作台卡片 --- */
.hero-card {
  margin-top: 0;
  padding: 0;
  border-radius: 24rpx;
  overflow: hidden;
  /* 复用全局 .hero 渐变；此处覆盖 padding */
}

.hero-grid {
  padding: 20rpx 22rpx;
  display: flex;
  align-items: center;
  gap: 0;
}

.hero-main {
  flex: 1;
  min-width: 0;
}

.hero-env-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.35);
  background: rgba(15, 23, 42, 0.16);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}

.h-title {
  margin-top: 0;
  font-size: 40rpx;
  font-weight: 780;
  line-height: 1.2;
  letter-spacing: 0.3rpx;
  color: #ffffff;
}

.hero-task-strip {
  margin-top: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  background: rgba(15, 23, 42, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
}

.hero-task-empty {
  padding-bottom: 16rpx;
}

.hero-task-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.78);
}

.hero-task-name {
  margin-top: 6rpx;
  font-size: 30rpx;
  font-weight: 780;
  color: #ffffff;
}

.hero-task-meta {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.86);
}

.hero-task-detail {
  margin-top: 6rpx;
  font-size: 21rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.70);
}

.hero-progress-wrap {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.hero-progress-bar {
  flex: 1;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.20);
  overflow: hidden;
}

.hero-progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #ffffff;
  transition: width 0.4s ease;
}

.hero-progress-text {
  font-size: 21rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.82);
  flex-shrink: 0;
}

.hero-task-btn {
  margin-top: 12rpx;
  width: auto;
  min-width: 200rpx;
  padding: 0 24rpx;
  background: #ffffff;
  color: var(--brand-700, #0A6F43);
}

/* --- Section --- */
.section {
  margin-top: 16rpx;
}

.section-head {
  margin: 0 2rpx 10rpx;
}

/* --- 排序/筛选工具栏 --- */
.toolbar-row {
  margin-top: 8rpx;
  padding: 10rpx 14rpx;
  background: var(--neutral-50, #F8FAFC);
  border: 1rpx solid var(--neutral-200, #E2E8F0);
  border-radius: 16rpx;
  margin-bottom: 4rpx;
}

.sort-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}

.sort-label {
  font-size: 22rpx;
  color: var(--neutral-500, #64748B);
  margin-right: 2rpx;
}

.sort-chip {
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--neutral-200, #E2E8F0);
  background: var(--bg-surface, #FFFFFF);
  color: var(--neutral-700, #334155);
  font-size: 22rpx;
  font-weight: 600;
  transition: background 120ms ease, border-color 120ms ease, color 120ms ease;
}

.sort-chip.active {
  background: var(--brand-50, #F1FCF5);
  border-color: var(--brand-100, #DDF7E8);
  color: var(--brand-700, #0A6F43);
  font-weight: 700;
}

.filter-row {
  margin-top: 8rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.filter-chip {
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--neutral-200, #E2E8F0);
  background: var(--bg-surface, #FFFFFF);
  color: var(--neutral-700, #334155);
  font-size: 22rpx;
  font-weight: 600;
  transition: background 120ms ease, border-color 120ms ease, color 120ms ease;
}

.filter-chip.active {
  background: #DCFCE7;
  border-color: #86EFAC;
  color: #166534;
  font-weight: 700;
}

/* --- 赛事列表卡 --- */
.swipe-row {
  position: relative;
  overflow: hidden;
  border-radius: 20rpx;
  margin-top: 12rpx;
  border: 1rpx solid var(--neutral-200, #E2E8F0);
  box-shadow: var(--shadow-soft);
}

.swipe-row.card {
  padding: 0;
  margin-top: 12rpx;
}

.swipe-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 160rpx;
  display: flex;
  justify-content: flex-end;
  z-index: 0;
}

.del-btn {
  width: 160rpx;
  background: linear-gradient(145deg, #EF5350, #E5484D);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  font-size: 28rpx;
}

.swipe-content {
  position: relative;
  z-index: 1;
  width: 100%;
  background: var(--bg-surface, #FFFFFF);
  will-change: transform;
  border-left: 6rpx solid transparent;
  transition: transform 100ms ease;
}

.swipe-content.tone-running {
  border-left-color: var(--brand-500, #18B368);
}

.swipe-content.tone-draft {
  border-left-color: var(--neutral-300, #CBD5E1);
}

.swipe-content.tone-finished {
  border-left-color: var(--warning, #D97706);
}

.swipe-content.tone-missing,
.swipe-content.tone-unknown {
  border-left-color: var(--neutral-300, #CBD5E1);
}

.t-card {
  padding: 16rpx 16rpx 14rpx 18rpx;
}

.t-top {
  align-items: flex-start;
}

.t-title {
  font-size: 29rpx;
  font-weight: 740;
  color: var(--neutral-950, #0F172A);
}

.t-stats {
  margin-top: 10rpx;
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.pill {
  background: var(--neutral-100, #F1F5F9);
  border: 1rpx solid var(--neutral-200, #E2E8F0);
  color: var(--neutral-700, #334155);
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.t-time {
  margin-top: 8rpx;
  color: var(--neutral-500, #64748B);
}

.t-actions {
  margin-top: 10rpx;
  display: flex;
  justify-content: flex-end;
  gap: 8rpx;
}

.t-copy-link,
.t-quick-action {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: var(--brand-50, #F1FCF5);
  border: 1rpx solid var(--brand-100, #DDF7E8);
  color: var(--brand-700, #0A6F43);
  font-size: 22rpx;
  font-weight: 700;
  transition: background 100ms ease;
}

.t-quick-action {
  background: var(--info-100, #EAF0FF);
  border-color: #BFDBFE;
  color: var(--info-500, #4F7BFF);
}

/* --- Skeleton 更拟真 --- */
.skeleton-list {
  margin-top: 8rpx;
}

.skeleton-card-wrap {
  margin-top: 12rpx;
  border-radius: 20rpx;
  border: 1rpx solid var(--neutral-200, #E2E8F0);
  overflow: hidden;
}

.skeleton-card-wrap .skeleton-card {
  margin-top: 0;
  border: none;
  border-left: 6rpx solid var(--neutral-200, #E2E8F0);
}

.skeleton-badge {
  width: 80rpx;
  height: 32rpx;
  border-radius: 999rpx;
}

/* --- Profile Nudge --- */
.profile-nudge {
  margin-top: 0;
  border-radius: 20rpx;
  border: 1rpx solid var(--neutral-200, #E2E8F0);
}

.profile-nudge-actions {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.profile-nudge-later {
  font-size: 24rpx;
  color: var(--neutral-500, #64748B);
}

/* --- Onboarding --- */
.onboarding {
  margin-top: 0;
}

.guide-step {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.guide-index {
  width: 36rpx;
  height: 36rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: var(--brand-50, #F1FCF5);
  color: var(--brand-700, #0A6F43);
  font-size: 22rpx;
  font-weight: 700;
}

.guide-text {
  flex: 1;
  min-width: 0;
  font-size: 25rpx;
  color: var(--neutral-950, #0F172A);
}

.onboarding-later {
  margin-top: 12rpx;
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: var(--neutral-500, #64748B);
}

/* --- Ad Slot --- */
.ad-breakpoint {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 18rpx;
  border: 1rpx dashed var(--neutral-200, #E2E8F0);
  background: var(--neutral-50, #F8FAFC);
}

.ad-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 3rpx 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--neutral-200, #E2E8F0);
  background: var(--bg-surface, #FFFFFF);
  color: var(--neutral-500, #64748B);
  font-size: 21rpx;
  margin-bottom: 8rpx;
}

/* --- Retry Box --- */
.retry-box {
  margin-top: 16rpx;
  padding: 12rpx 16rpx;
  border-radius: 14rpx;
  border: 1rpx solid var(--neutral-200, #E2E8F0);
  background: var(--bg-section, #F7FAFC);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

/* --- Responsive --- */
@media (max-width: 360px) {
  .hero-grid {
    flex-direction: column;
  }

  .profile-nudge-actions {
    flex-direction: column;
    align-items: stretch;
  }

  .toolbar-row {
    padding: 8rpx 10rpx;
  }
}
