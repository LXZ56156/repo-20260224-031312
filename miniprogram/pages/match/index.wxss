.match-page {
  padding-top: 24rpx;
}

.sync-banner {
  margin-bottom: 12rpx;
  padding: 12rpx 16rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.sync-warning {
  background: #fef3c7;
  border: 1rpx solid #fcd34d;
  color: #92400e;
}

.sync-info {
  background: #eff6ff;
  border: 1rpx solid #bfdbfe;
  color: #1d4ed8;
}

.sync-neutral {
  background: #f8fafc;
  border: 1rpx solid #dbe5ef;
  color: #334155;
}

.sync-banner-main {
  flex: 1;
  min-width: 0;
}

.sync-banner-text {
  font-size: 23rpx;
  font-weight: 700;
}

.sync-banner-meta {
  margin-top: 4rpx;
  font-size: 21rpx;
  line-height: 1.5;
  opacity: 0.88;
}

.sync-banner-action {
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 760;
}

.hero-head {
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
}

.batch-progress {
  margin-top: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
}

.batch-progress-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.batch-progress-label {
  font-size: 22rpx;
  font-weight: 760;
  color: rgba(255, 255, 255, 0.9);
}

.batch-progress-text {
  font-size: 21rpx;
  color: rgba(255, 255, 255, 0.72);
}

.batch-progress-bar {
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  overflow: hidden;
}

.batch-progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #ffffff;
  transition: width 0.4s ease;
}

.quick-scores {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  flex: 1;
  min-width: 0;
}

.quick-score-chip {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #ecf7f0;
  border: 1rpx solid #cfe6d7;
  color: #0f7a46;
  font-size: 23rpx;
  font-weight: 760;
}

.quick-score-chip:active {
  background: #dcfce7;
}

.section-title {
  font-size: 30rpx;
  font-weight: 760;
}

.match-vs {
  margin-top: 12rpx;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.4;
  color: var(--text-1, #0f172a);
}

.vs {
  margin: 0 10rpx;
  color: #6b7280;
  font-weight: 700;
}

.score-row {
  margin-top: 14rpx;
  display: flex;
  gap: 16rpx;
}

.score-col {
  width: calc((100% - 16rpx) / 2);
}

.tiny {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #6b7280;
  word-break: break-word;
}

.score-box {
  margin-top: 10rpx;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
  background: #f9fafb;
  border: 1rpx solid var(--line-soft, #dbe5ef);
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-1, #0f172a);
  text-align: center;
}

.score-tip {
  margin-top: 14rpx;
}

.lock-panel {
  margin-top: 12rpx;
  padding: 14rpx;
  border-radius: 14rpx;
  border: 1rpx solid #dbe5ef;
  background: #f8fbff;
}

.lock-hint {
  font-size: 24rpx;
  color: #334155;
}

.lock-actions {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.lock-btn-primary {
  width: auto;
  min-width: 200rpx;
}

.lock-btn {
  width: auto;
  min-width: 160rpx;
}

.score-toolbar {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
}

.mode-undo {
  margin-left: auto;
}

.mode-undo.disabled {
  opacity: 0.45;
}

.score-wheel {
  margin-top: 10rpx;
  min-height: 72rpx;
  line-height: 72rpx;
  border-radius: 16rpx;
  border: 1rpx solid #dce5ef;
  background: #f8fbff;
  font-size: 36rpx;
  font-weight: 760;
  text-align: center;
}

.submit-bar {
  position: sticky;
  bottom: calc(env(safe-area-inset-bottom) + 10rpx);
  margin-top: 14rpx;
  padding: 10rpx;
  border-radius: 20rpx;
  border: 1rpx solid #dbe5ef;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.12);
  z-index: 9;
}

.submit-btn {
  margin-top: 0 !important;
}

.retry-box {
  margin-top: 16rpx;
  padding: 14rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--line-soft, #dbe5ef);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.state-title {
  font-size: 32rpx;
  font-weight: 760;
  margin-bottom: 8rpx;
}

@media (max-width: 360px) {
  .score-row {
    flex-direction: column;
    gap: 12rpx;
  }

  .score-col {
    width: 100%;
  }
}
