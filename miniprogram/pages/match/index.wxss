/* ============================================================
   MATCH PAGE — 裁判录分终端 v2
   比分舞台是第一视觉中心，8pt 网格，design token 驱动
   ============================================================ */

/* --- 页面容器 --- */
.match-page {
  padding-top: 16rpx;
}

/* --- Sync Banner（固定占位，hidden 切换） --- */
/* 样式复用全局 app.wxss 中的 .sync-banner / .sync-* tone 类 */
/* 仅保留 match 页的间距微调 */
.match-page > .sync-banner {
  margin-bottom: 8rpx;
}

/* --- Hero 紧凑化 --- */
.hero-compact {
  padding: 20rpx 24rpx;
}

.hero-head {
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
}

.hero-title-compact {
  font-size: 32rpx;
  font-weight: 780;
  line-height: 1.25;
}

.hero-sub-compact {
  margin-top: 4rpx;
  font-size: 22rpx;
  opacity: 0.82;
  line-height: 1.4;
}

.match-status-tag {
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
}

/* --- 批量录分进度 --- */
.batch-progress {
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
}

.batch-progress-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.batch-progress-label {
  font-size: 22rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.9);
}

.batch-progress-text {
  font-size: 21rpx;
  color: rgba(255, 255, 255, 0.68);
}

.batch-progress-bar {
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  overflow: hidden;
}

.batch-progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #ffffff;
  transition: width 0.4s ease;
}

/* --- 对阵区 --- */
.match-vs {
  margin-top: 8rpx;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.4;
  color: var(--neutral-950);
}

.vs {
  margin: 0 10rpx;
  color: var(--neutral-500);
  font-weight: 700;
}

/* --- 比分舞台（统一容器） --- */
.score-stage {
  padding: 24rpx;
}

.score-badge {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: var(--neutral-100);
  color: var(--neutral-500);
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
}

/* --- 比分行 --- */
.score-row {
  margin-top: 16rpx;
  display: flex;
  gap: 16rpx;
  align-items: stretch;
}

.score-col {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.score-divider {
  width: 2rpx;
  align-self: stretch;
  margin: 8rpx 0;
  background: var(--neutral-200);
  border-radius: 999rpx;
  flex-shrink: 0;
}

/* --- 选手名称 --- */
.score-player-name {
  margin-bottom: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--neutral-700);
  line-height: 1.4;
  word-break: break-word;
}

/* --- 比分盒（只读） — 大字号，赛事工具感 --- */
.score-box {
  padding: 24rpx;
  border-radius: 18rpx;
  background: var(--neutral-100);
  border: 2rpx solid var(--neutral-200);
  font-size: 56rpx;
  font-weight: 820;
  letter-spacing: -0.5rpx;
  color: var(--neutral-950);
  text-align: center;
  line-height: 1.15;
  font-variant-numeric: tabular-nums;
  transition: background 160ms ease, border-color 160ms ease;
}

.score-box-readonly {
  background: var(--bg-section);
  border-color: var(--neutral-200);
}

/* --- 比分滚轮（编辑态） --- */
.score-wheel {
  margin-top: 0;
  padding: 24rpx;
  min-height: auto;
  line-height: 1.15;
  border-radius: 18rpx;
  border: 2rpx solid var(--brand-500);
  background: var(--brand-50);
  font-size: 56rpx;
  font-weight: 820;
  letter-spacing: -0.5rpx;
  text-align: center;
  color: var(--brand-700);
  font-variant-numeric: tabular-nums;
  transition: border-color 160ms ease, background 160ms ease;
}

.score-wheel:active {
  background: var(--brand-100);
}

/* --- 提示文字 --- */
.score-tip {
  margin-top: 16rpx;
  text-align: center;
}

/* --- 锁态面板 — 产品化设计 --- */
.lock-panel {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--neutral-200);
  background: var(--neutral-50);
}

.lock-icon-row {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.lock-icon {
  font-size: 28rpx;
  flex-shrink: 0;
  line-height: 1.5;
}

.lock-hint {
  font-size: 25rpx;
  color: var(--neutral-700);
  line-height: 1.5;
}

.lock-actions {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.lock-btn-primary {
  width: auto;
  min-width: 200rpx;
  padding: 0 24rpx;
}

.lock-btn {
  width: auto;
  min-width: 160rpx;
  padding: 0 24rpx;
}

/* --- 快捷比分工具栏 --- */
.score-toolbar {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.quick-scores {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
  flex: 1;
  min-width: 0;
}

.quick-score-chip {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: var(--brand-50);
  border: 1rpx solid var(--brand-100);
  color: var(--brand-700);
  font-size: 22rpx;
  font-weight: 700;
  transition: background 100ms ease, transform 100ms ease;
}

.quick-score-chip:active {
  background: var(--brand-100);
  transform: scale(0.96);
}

.mode-undo {
  margin-left: auto;
  flex-shrink: 0;
}

.mode-undo.disabled {
  opacity: 0.4;
}

/* --- 底部提交栏 — 复用全局 bottom-tray --- */
/* .bottom-tray 样式已在 app.wxss 定义 */

/* --- 重试提交 — 复用全局 retry-box --- */
/* .retry-box 样式已在 app.wxss 定义 */

/* --- Skeleton 比分舞台 --- */
.skeleton-score-row {
  margin-top: 16rpx;
  display: flex;
  gap: 16rpx;
}

.skeleton-score-col {
  flex: 1;
}

.skeleton-score-box {
  height: 112rpx;
  border-radius: 18rpx;
}

/* --- 响应式：窄屏 --- */
@media (max-width: 360px) {
  .score-row {
    flex-direction: column;
    gap: 12rpx;
  }

  .score-col {
    width: 100%;
  }

  .score-divider {
    width: 100%;
    height: 2rpx;
    margin: 4rpx 0;
    align-self: auto;
  }
}
