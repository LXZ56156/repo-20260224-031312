<view class="container create-page">
  <view class="sync-banner sync-warning" hidden="{{!networkOffline}}">
    <view class="sync-banner-main">
      <view class="sync-banner-text">当前网络不可用，写入操作可能失败</view>
    </view>
  </view>

  <view class="hero create-hero reveal reveal-1">
    <view class="hero-title">创建比赛</view>
  </view>

  <view class="card panel create-panel reveal reveal-2">
    <view class="section-head">
      <view class="section-title">基本信息</view>
      <text class="count-pill">一步创建</text>
    </view>

    <view class="form-block">
      <view class="field-label">赛事名称</view>
      <input class="input" placeholder="赛事名称（例如：周末比赛）" bindinput="onName" value="{{name}}" />
    </view>
  </view>

  <view class="card panel create-panel reveal reveal-3">
    <view class="section-head">
      <view class="section-title">快速参数</view>
      <text class="count-pill">创建时可预设</text>
    </view>

    <view class="preset-row">
      <view
        class="preset-chip {{quickPresetKey===item.key ? 'active' : ''}}"
        wx:for="{{presetOptions}}"
        wx:key="key"
        data-key="{{item.key}}"
        bindtap="applyPreset"
      >
        {{item.label}}
      </view>
    </view>

    <view class="param-row">
      <view class="param-col">
        <view class="field-label">总场次</view>
        <picker mode="selector" range="{{totalMatchOptions}}" value="{{totalMatchIndex}}" bindchange="onPickTotalMatches">
          <view class="picker param-picker">{{totalMatches}}</view>
        </picker>
      </view>
      <view class="param-col">
        <view class="field-label">每轮最多场数</view>
        <picker mode="selector" range="{{courtOptions}}" value="{{courtIndex}}" bindchange="onPickCourts">
          <view class="picker param-picker">{{courts}}</view>
        </picker>
      </view>
    </view>

    <view class="param-row">
      <view class="param-col">
        <view class="field-label">活动时长</view>
        <picker mode="selector" range="{{sessionMinuteOptions}}" value="{{sessionMinuteIndex}}" bindchange="onPickSessionMinutes">
          <view class="picker param-picker">{{sessionMinutes}} 分钟</view>
        </picker>
      </view>
      <view class="param-col">
        <view class="field-label">单场占用时间</view>
        <picker mode="selector" range="{{slotMinuteOptions}}" value="{{slotMinuteIndex}}" bindchange="onPickSlotMinutes">
          <view class="picker param-picker">{{slotMinutes}} 分钟</view>
        </picker>
      </view>
    </view>

    <view class="param-row">
      <view class="param-col">
        <view class="field-label">每局分制</view>
        <picker mode="selector" range="{{pointsOptions}}" value="{{pointsIndex}}" bindchange="onPickPointsPerGame">
          <view class="picker param-picker">{{pointsPerGame}} 分</view>
        </picker>
      </view>
      <view class="param-col" wx:if="{{showSquadEndCondition}}">
        <view class="field-label">结束条件</view>
        <picker mode="selector" range="{{endConditionOptions}}" range-key="label" value="{{endConditionIndex}}" bindchange="onPickEndConditionType">
          <view class="picker param-picker">{{endConditionOptions[endConditionIndex].label}}</view>
        </picker>
      </view>
    </view>

    <view class="param-row" wx:if="{{showSquadEndCondition}}">
      <view class="param-col">
        <view class="field-label">{{endConditionTargetLabel}}</view>
        <picker wx:if="{{showEndConditionTargetPicker}}" mode="selector" range="{{endConditionTargetOptions}}" value="{{endConditionTargetIndex}}" bindchange="onPickEndConditionTarget">
          <view class="picker param-picker">{{endConditionTarget}} {{endConditionTargetUnit}}</view>
        </picker>
        <view wx:else class="picker param-picker disabled">{{endConditionTarget}} {{endConditionTargetUnit}}</view>
      </view>
      <view class="param-col"></view>
    </view>
  </view>

  <view class="card panel-soft capacity-hint reveal reveal-3" wx:if="{{capacityHintDetail}}">
    <view class="capacity-hint-text muted small">{{capacityHintDetail}}</view>
  </view>

  <view class="retry-box panel-soft" wx:if="{{canRetryAction}}">
    <view class="muted small">{{lastFailedActionText}}</view>
    <button class="btn btn-subtle btn-sm" bindtap="retryLastAction">重试上次操作</button>
  </view>

  <view class="bottom-tray create-actions reveal reveal-4">
    <button class="btn btn-primary" bindtap="handleCreate" loading="{{createBusy}}" disabled="{{createBusy}}">创建并进入</button>
  </view>
</view>
