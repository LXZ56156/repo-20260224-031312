.container.safe-bottom {
  padding-bottom: calc(env(safe-area-inset-bottom) + 24rpx);
}

.lobby-page {
  padding-top: 24rpx;
}

.lobby-page.has-next-action {
  padding-bottom: calc(env(safe-area-inset-bottom) + 184rpx);
}

.offline-banner {
  margin-bottom: 12rpx;
  padding: 10rpx 14rpx;
  border-radius: 14rpx;
  background: #fef3c7;
  border: 1rpx solid #fcd34d;
  color: #92400e;
  font-size: 23rpx;
}

.lobby-page .hero {
  margin-bottom: 16rpx;
  padding: 30rpx;
  border-radius: 30rpx;
  background:
    radial-gradient(circle at 88% 20%, rgba(255, 255, 255, 0.35) 0%, rgba(255, 255, 255, 0) 34%),
    linear-gradient(132deg, #0f9a56 0%, #1eb164 58%, #45c67e 100%);
}

.hero-top {
  justify-content: space-between;
  align-items: flex-start;
  gap: 14rpx;
}

.hero-title {
  font-size: 39rpx;
  font-weight: 860;
  letter-spacing: 1rpx;
}

.hero-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.45;
  opacity: 0.94;
}

.hero-meta {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.hero-shortcuts {
  margin-top: 12rpx;
  display: flex;
  justify-content: flex-end;
}

.hero-shortcut-btn {
  min-width: 176rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #ffffff;
  border: 1rpx solid rgba(255, 255, 255, 0.4);
}

.meta-pill {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.26);
  font-size: 23rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-pill.tappable:active {
  transform: translateY(1rpx);
  filter: saturate(1.05);
}

.meta-label {
  opacity: 0.9;
}

.meta-value {
  font-weight: 760;
}

.meta-badge {
  margin-left: 4rpx;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.18);
  font-size: 21rpx;
}

.meta-link {
  margin-left: 2rpx;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.14);
  font-size: 21rpx;
  font-weight: 700;
}

.meta-referee.on {
  background: rgba(255, 255, 255, 0.3);
  border-color: rgba(255, 255, 255, 0.55);
}

.meta-referee.off {
  background: rgba(0, 0, 0, 0.1);
}

.meta-admin,
.meta-player {
  background: rgba(255, 255, 255, 0.24);
}

.section-title {
  font-size: 30rpx;
  font-weight: 760;
}

.rule-chips {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.rule-chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #eef4fb;
  border: 1rpx solid #dce5ef;
  color: #334155;
  font-size: 23rpx;
  font-weight: 700;
}

.info-highlight {
  margin-top: 12rpx;
  padding: 12rpx 14rpx;
  border-radius: 14rpx;
  border: 1rpx solid #dce5ef;
  background: #f7fafd;
  color: var(--text-1, #0f172a);
  font-size: 26rpx;
  font-weight: 700;
}

.row-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.link-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  color: var(--brand-strong, #14804b);
  font-weight: 760;
  font-size: 25rpx;
  padding: 0 10rpx;
  min-height: 48rpx;
  border-radius: 12rpx;
}

.player-grid {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx 12rpx;
}

.player-cell {
  width: calc((100% - 36rpx) / 4);
  min-width: 132rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 9rpx;
}

.player-avatar {
  width: 90rpx;
  height: 90rpx;
  border-radius: 999rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.35);
}

.player-avatar-img {
  width: 90rpx;
  height: 90rpx;
}

.player-initial {
  font-size: 34rpx;
  font-weight: 860;
  color: #fff;
}

.player-name {
  width: 100%;
  font-size: 24rpx;
  color: var(--text-1, #0f172a);
  font-weight: 700;
  text-align: center;
}

.player-gender {
  font-size: 22rpx;
  color: var(--text-2, #64748b);
}

.profile-panel {
  padding-top: 22rpx;
}

.profile-hint {
  margin-top: 8rpx;
  margin-bottom: 14rpx;
}

.profile-col {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.profile-avatar {
  width: 100rpx;
  height: 100rpx;
  border: 2rpx solid #dce6ef;
}

.profile-input {
  margin-top: 14rpx;
  text-align: center;
  padding-left: 0;
  padding-right: 0;
}

.profile-inline-tip {
  margin-top: 8rpx;
}

.profile-actions {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.profile-actions-center {
  width: 100%;
  justify-content: center;
  margin-top: 12rpx;
  margin-bottom: 12rpx;
}

.profile-actions-center .btn-mini {
  min-width: 220rpx;
  background: #e9f0f7;
}

.profile-actions-center .profile-quick-btn {
  background: linear-gradient(135deg, var(--brand, #1ea65e), var(--brand-strong, #14804b));
  color: #ffffff;
}

.admin-panel {
  padding-top: 22rpx;
}

.draft-prep {
  margin-top: 12rpx;
  padding: 14rpx;
  border-radius: 18rpx;
  border: 1rpx solid #dde6f0;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.prep-tile {
  width: calc((100% - 10rpx) / 2);
  min-height: 120rpx;
  border-radius: 14rpx;
  border: 1rpx solid #e2eaf3;
  background: #f8fbff;
  padding: 12rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.prep-tile:active {
  background: #eef5fc;
}

.prep-indicator {
  width: 18rpx;
  height: 18rpx;
  border-radius: 999rpx;
  background: #94a3b8;
  flex: none;
}

.prep-indicator.ok {
  background: var(--brand-strong, #14804b);
}

.prep-main {
  flex: 1;
  min-width: 0;
}

.prep-title {
  font-size: 24rpx;
  color: var(--text-1, #0f172a);
  font-weight: 760;
}

.prep-sub {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--text-2, #64748b);
}

.prep-jump {
  font-size: 22rpx;
  color: var(--brand-strong, #14804b);
  font-weight: 700;
  white-space: nowrap;
}

.quick-import {
  margin-top: 14rpx;
  border-radius: 18rpx;
  border: 1rpx solid #dde6f0;
  padding: 14rpx;
}

.quick-config {
  margin-top: 14rpx;
  border-radius: 18rpx;
  border: 1rpx solid #dde6f0;
  padding: 14rpx;
}

.quick-config-head {
  font-size: 26rpx;
  font-weight: 760;
  color: var(--text-1, #0f172a);
}

.quick-config-row {
  margin-top: 10rpx;
  display: flex;
  gap: 12rpx;
}

.quick-config-col {
  width: calc((100% - 12rpx) / 2);
}

.quick-config-label {
  margin-bottom: 8rpx;
  color: var(--text-2, #64748b);
  font-size: 24rpx;
}

.quick-config-picker {
  min-height: 76rpx;
  line-height: 76rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--line-soft, #dbe5ef);
  background: var(--surface-2, #edf2f8);
  padding: 0 18rpx;
  font-size: 30rpx;
  color: var(--text-1, #0f172a);
}

.quick-config-tip {
  margin-top: 10rpx;
}

.quick-recommend-chips {
  margin-top: 10rpx;
}

.quick-config-save {
  margin-top: 12rpx;
}

.quick-import-head {
  font-size: 26rpx;
  font-weight: 760;
  color: var(--text-1, #0f172a);
}

.quick-import-input {
  margin-top: 10rpx;
  min-height: 168rpx;
}

.quick-import-actions {
  margin-top: 12rpx;
}

.quick-import-result {
  margin-top: 12rpx;
  padding: 12rpx;
  border-radius: 14rpx;
  border: 1rpx solid #d7e5f3;
  background: #f7fbff;
}

.quick-import-result-title {
  font-size: 24rpx;
  font-weight: 760;
  color: #0f172a;
}

.fixed-team {
  margin-top: 14rpx;
  border-radius: 18rpx;
  border: 1rpx solid #dde6f0;
  padding: 14rpx;
}

.fixed-team-head {
  align-items: center;
}

.fixed-team-list {
  margin-top: 10rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.fixed-team-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  border: 1rpx solid #dde6f0;
  border-radius: 14rpx;
  background: #f8fbff;
  padding: 10rpx 12rpx;
}

.fixed-team-main {
  flex: 1;
  min-width: 0;
}

.fixed-team-name {
  font-size: 25rpx;
  font-weight: 760;
  color: #0f172a;
}

.fixed-team-create {
  margin-top: 12rpx;
}

.fixed-team-name-input {
  margin-bottom: 10rpx;
}

.fixed-team-create-btn {
  margin-top: 12rpx;
}

.admin-actions {
  margin-top: 14rpx;
}

.admin-actions .btn {
  border-radius: 18rpx;
}

.admin-actions .btn[disabled] {
  opacity: 0.72;
  filter: saturate(0.7);
}

.share-pulse {
  animation: sharePulse 700ms ease-in-out 2;
}

@keyframes sharePulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.03); }
  100% { transform: scale(1); }
}

.retry-box {
  margin-top: 16rpx;
  padding: 14rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--line-soft, #dbe5ef);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.loading-title {
  font-size: 32rpx;
  font-weight: 760;
  margin-bottom: 8rpx;
}

.next-action-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(env(safe-area-inset-bottom) + 18rpx);
  z-index: 99;
  display: flex;
  gap: 12rpx;
  align-items: center;
  padding: 12rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid #dbe5ef;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.16);
}

.next-action-bar .btn {
  width: auto;
  margin-top: 0 !important;
}

.next-primary {
  flex: 1;
}

.pcolor-0 { background: #16a34a; }
.pcolor-1 { background: #0ea5e9; }
.pcolor-2 { background: #f59e0b; }
.pcolor-3 { background: #8b5cf6; }
.pcolor-4 { background: #ef4444; }
.pcolor-5 { background: #14b8a6; }

@media (max-width: 360px) {
  .prep-tile {
    width: 100%;
  }

  .player-cell {
    width: calc((100% - 24rpx) / 3);
    min-width: 0;
  }

  .next-action-bar {
    flex-direction: column;
  }

  .next-primary,
  .next-action-bar .btn {
    width: 100%;
    flex: none;
  }
}
