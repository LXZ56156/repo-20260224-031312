.container.safe-bottom {
  padding-bottom: calc(env(safe-area-inset-bottom) + 24rpx);
}

.lobby-page {
  padding-top: 24rpx;
}

.lobby-page.has-next-action {
  padding-bottom: calc(env(safe-area-inset-bottom) + 184rpx);
}

.offline-banner {
  margin-bottom: 12rpx;
  padding: 10rpx 14rpx;
  border-radius: 14rpx;
  background: #fef3c7;
  border: 1rpx solid #fcd34d;
  color: #92400e;
  font-size: 23rpx;
}

.lobby-page .hero {
  margin-bottom: 16rpx;
  padding: 30rpx;
  border-radius: 30rpx;
  background:
    radial-gradient(circle at 88% 20%, rgba(255, 255, 255, 0.35) 0%, rgba(255, 255, 255, 0) 34%),
    linear-gradient(132deg, #0f9a56 0%, #1eb164 58%, #45c67e 100%);
}

.hero-top {
  justify-content: space-between;
  align-items: flex-start;
  gap: 14rpx;
}

.hero-title {
  font-size: 39rpx;
  font-weight: 860;
  letter-spacing: 1rpx;
}

.hero-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.45;
  opacity: 0.94;
}

.hero-meta {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.meta-pill {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.26);
  font-size: 23rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-label {
  opacity: 0.9;
}

.meta-value {
  font-weight: 760;
}

.meta-badge {
  margin-left: 4rpx;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.18);
  font-size: 21rpx;
}

.meta-referee.on {
  background: rgba(255, 255, 255, 0.3);
  border-color: rgba(255, 255, 255, 0.55);
}

.meta-referee.off {
  background: rgba(0, 0, 0, 0.1);
}

.meta-admin,
.meta-player {
  background: rgba(255, 255, 255, 0.24);
}

.section-title {
  font-size: 30rpx;
  font-weight: 760;
}

.info-row {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
}

.info-label {
  width: 154rpx;
  color: var(--text-2, #64748b);
  font-size: 25rpx;
}

.info-value {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: var(--text-1, #0f172a);
  line-height: 1.4;
}

.row-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.link-btn {
  background: transparent;
  color: var(--brand-strong, #14804b);
  font-weight: 760;
  font-size: 25rpx;
  padding: 0 8rpx;
  height: 48rpx;
  line-height: 48rpx;
  border-radius: 12rpx;
}

button.link-btn::after {
  border: none;
}

.player-grid {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx 12rpx;
}

.player-cell {
  width: calc((100% - 36rpx) / 4);
  min-width: 132rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 9rpx;
}

.player-avatar {
  width: 90rpx;
  height: 90rpx;
  border-radius: 999rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.35);
}

.player-avatar-img {
  width: 90rpx;
  height: 90rpx;
}

.player-initial {
  font-size: 34rpx;
  font-weight: 860;
  color: #fff;
}

.player-name {
  width: 100%;
  font-size: 24rpx;
  color: var(--text-1, #0f172a);
  font-weight: 700;
  text-align: center;
}

.player-hint {
  margin-top: 12rpx;
}

.profile-panel {
  padding-top: 22rpx;
}

.profile-hint {
  margin-top: 8rpx;
  margin-bottom: 14rpx;
}

.profile-col {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.profile-avatar {
  width: 100rpx;
  height: 100rpx;
  border: 2rpx solid #dce6ef;
}

.profile-input {
  margin-top: 14rpx;
  text-align: center;
  padding-left: 0;
  padding-right: 0;
}

.profile-actions {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.profile-actions-center {
  width: 100%;
  justify-content: center;
  margin-top: 12rpx;
  margin-bottom: 12rpx;
}

.profile-actions-center .btn-mini {
  min-width: 220rpx;
  background: #e9f0f7;
}

.action-panel {
  padding-top: 22rpx;
}

.action-row {
  margin-top: 12rpx;
}

.action-row .btn {
  border-radius: 18rpx;
}

.admin-panel {
  padding-top: 22rpx;
}

.checklist {
  margin-top: 12rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid #dde6f0;
}

.check-row {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.check-row:first-child {
  margin-top: 0;
}

.check-tappable {
  border-radius: 12rpx;
  padding: 6rpx 4rpx;
}

.check-tappable:active {
  background: #eef4fb;
}

.check-icon {
  width: 34rpx;
  color: #94a3b8;
  font-size: 27rpx;
  font-weight: 860;
}

.check-icon.ok {
  color: var(--brand-strong, #14804b);
}

.check-text {
  font-size: 26rpx;
  color: var(--text-1, #0f172a);
}

.checklist-hint {
  margin-top: 8rpx;
}

.quick-import {
  margin-top: 14rpx;
  border-radius: 18rpx;
  border: 1rpx solid #dde6f0;
  padding: 14rpx;
}

.quick-import-head {
  font-size: 26rpx;
  font-weight: 760;
  color: var(--text-1, #0f172a);
}

.quick-import-input {
  margin-top: 10rpx;
  min-height: 168rpx;
}

.quick-import-actions {
  margin-top: 12rpx;
}

.admin-actions {
  margin-top: 14rpx;
}

.admin-actions .btn-row {
  margin-bottom: 12rpx;
}

.admin-actions .btn {
  border-radius: 18rpx;
}

.admin-actions .btn[disabled] {
  opacity: 0.72;
  filter: saturate(0.7);
}

.share-pulse {
  animation: sharePulse 700ms ease-in-out 2;
}

@keyframes sharePulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.03); }
  100% { transform: scale(1); }
}

.retry-box {
  margin-top: 16rpx;
  padding: 14rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--line-soft, #dbe5ef);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.loading-title {
  font-size: 32rpx;
  font-weight: 760;
  margin-bottom: 8rpx;
}

.next-action-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(env(safe-area-inset-bottom) + 18rpx);
  z-index: 99;
  display: flex;
  gap: 12rpx;
  align-items: center;
  padding: 12rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid #dbe5ef;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.16);
}

.next-action-bar .btn {
  width: auto;
  margin-top: 0 !important;
}

.next-primary {
  flex: 1.2;
}

.next-secondary {
  flex: 1;
}

.pcolor-0 { background: #16a34a; }
.pcolor-1 { background: #0ea5e9; }
.pcolor-2 { background: #f59e0b; }
.pcolor-3 { background: #8b5cf6; }
.pcolor-4 { background: #ef4444; }
.pcolor-5 { background: #14b8a6; }

@media (max-width: 360px) {
  .player-cell {
    width: calc((100% - 24rpx) / 3);
    min-width: 0;
  }

  .next-action-bar {
    flex-direction: column;
  }

  .next-primary,
  .next-secondary {
    width: 100%;
    flex: none;
  }
}
