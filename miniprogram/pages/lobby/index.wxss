/* ============================================================
   LOBBY — 赛事大厅控制台
   轻专业赛事中控台风 · 8pt grid · Design System v2 tokens
   ============================================================ */

/* --- Layout --- */
.container.safe-bottom {
  padding-bottom: calc(env(safe-area-inset-bottom) + 24rpx);
}

.lobby-page {
  padding-top: 16rpx;
}

/* --- Hero (compact console style) --- */
.lobby-page .hero {
  margin-bottom: 16rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background:
    radial-gradient(ellipse at 85% 15%, rgba(255, 255, 255, 0.2) 0%, transparent 50%),
    linear-gradient(135deg, var(--brand-700) 0%, var(--brand-500) 55%, #2DD47A 100%);
  box-shadow: 0 6rpx 20rpx rgba(24, 179, 104, 0.14);
}

.lobby-page .hero.hero-draft {
  background:
    radial-gradient(ellipse at 85% 15%, rgba(255, 255, 255, 0.16) 0%, transparent 50%),
    linear-gradient(135deg, #475569 0%, #64748b 55%, #7d8fa3 100%);
  box-shadow: 0 6rpx 20rpx rgba(71, 85, 105, 0.18);
}

.lobby-page .hero.hero-finished {
  background:
    radial-gradient(ellipse at 85% 15%, rgba(255, 255, 255, 0.2) 0%, transparent 50%),
    linear-gradient(135deg, #d97706 0%, #f59e0b 55%, #fbbf24 100%);
  box-shadow: 0 6rpx 20rpx rgba(245, 158, 11, 0.18);
}

.hero-top {
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
}

.hero-title {
  font-size: 36rpx;
  font-weight: 780;
  letter-spacing: 0.5rpx;
  line-height: 1.25;
}

.hero-sub {
  margin-top: 4rpx;
  font-size: 23rpx;
  line-height: 1.4;
  opacity: 0.88;
}

/* Hero role badges — inline with title */
.hero-badges {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.hero-role-pill {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  font-size: 21rpx;
  font-weight: 600;
  white-space: nowrap;
}

/* KPI strip — single row compact chips */
.kpi-strip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 16rpx;
}

.kpi-chip {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.kpi-chip-value {
  font-size: 28rpx;
  font-weight: 800;
}

.kpi-chip-label {
  font-size: 21rpx;
  opacity: 0.82;
}

.kpi-settings {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  margin-left: auto;
}

.kpi-settings-icon {
  font-size: 26rpx;
}

/* --- State Overview (primary action rail) --- */
.state-overview {
  border-color: rgba(24, 179, 104, 0.15);
  box-shadow: 0 4rpx 16rpx rgba(24, 179, 104, 0.08);
}

.state-panel-summary {
  margin-top: 8rpx;
  font-size: 27rpx;
  line-height: 1.5;
  color: var(--neutral-950);
  font-weight: 700;
}

.state-checklist {
  margin-top: 16rpx;
  padding: 12rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--neutral-200);
  display: block;
}

.state-actions {
  margin-top: 16rpx;
}

.state-primary-btn {
  margin-top: 0 !important;
}

/* start button sticky */
.state-actions-sticky {
  position: sticky;
  bottom: calc(env(safe-area-inset-bottom) + 12rpx);
  z-index: 9;
  padding: 12rpx;
  margin: 0 -16rpx;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 20rpx;
  box-shadow: 0 -4rpx 16rpx rgba(15, 23, 42, 0.08);
}

.start-pulse {
  animation: startPulse 1.6s ease-in-out infinite;
}

@keyframes startPulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(20, 128, 75, 0.3); }
  50% { box-shadow: 0 0 0 12rpx rgba(20, 128, 75, 0); }
}

/* --- Checklist cards --- */
.prep-featured,
.prep-tile {
  border-radius: 16rpx;
  border: 1rpx solid var(--neutral-200);
  background: var(--bg-surface);
}

.prep-featured {
  padding: 18rpx;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.04);
}

.prep-featured:active,
.prep-tile:active {
  transform: translateY(1rpx);
}

.prep-secondary-grid {
  display: flex;
  gap: 8rpx;
  margin-top: 8rpx;
}

.prep-tile {
  flex: 1;
  min-height: 152rpx;
  padding: 14rpx;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 10rpx;
}

.prep-card-active {
  border-color: rgba(24, 179, 104, 0.28);
  background: linear-gradient(180deg, #f4fff9 0%, #ffffff 100%);
  box-shadow: 0 8rpx 22rpx rgba(24, 179, 104, 0.12);
}

.prep-card-done {
  border-color: rgba(24, 179, 104, 0.16);
  background: rgba(255, 255, 255, 0.98);
}

.prep-card-pending {
  border-color: var(--neutral-200);
  background: var(--bg-surface);
}

.prep-featured-top,
.prep-secondary-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.prep-featured-top {
  margin-bottom: 12rpx;
}

.prep-featured-main {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.prep-indicator {
  width: 16rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: var(--neutral-300);
  flex: none;
}

.prep-indicator-lg {
  width: 20rpx;
  height: 20rpx;
  margin-top: 8rpx;
}

.prep-indicator-ok {
  background: var(--brand-600);
}

.prep-indicator-active {
  background: var(--brand-600);
  box-shadow: 0 0 0 8rpx rgba(24, 179, 104, 0.14);
}

.prep-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 40rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(24, 179, 104, 0.1);
  color: var(--brand-700);
  font-size: 20rpx;
  font-weight: 700;
  white-space: nowrap;
}

.prep-badge-subtle {
  min-height: 32rpx;
  padding: 0 10rpx;
  background: var(--neutral-100);
  color: var(--neutral-500);
}

.prep-main {
  flex: 1;
  min-width: 0;
}

.prep-main-secondary {
  min-height: 0;
}

.prep-title {
  font-size: 24rpx;
  color: var(--neutral-950);
  font-weight: 700;
}

.prep-title-featured {
  font-size: 28rpx;
}

.prep-sub {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--neutral-500);
  line-height: 1.45;
}

.prep-sub-featured {
  font-size: 24rpx;
}

.prep-jump {
  font-size: 22rpx;
  color: var(--brand-600);
  font-weight: 700;
  white-space: nowrap;
}

.prep-jump-featured {
  font-size: 24rpx;
}

.prep-tile .prep-jump {
  margin-top: auto;
}

/* --- Section common --- */
.section-title {
  font-size: 30rpx;
  font-weight: 740;
}

.row-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.link-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  color: var(--brand-600);
  font-weight: 700;
  font-size: 25rpx;
  padding: 0 10rpx;
  min-height: 48rpx;
  border-radius: 12rpx;
}

/* --- Player Grid --- */
.player-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx 12rpx;
}

.player-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.player-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 999rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(15, 23, 42, 0.08);
}

.player-avatar-img {
  width: 88rpx;
  height: 88rpx;
}

.player-initial {
  font-size: 32rpx;
  font-weight: 800;
  color: #fff;
}

.player-name {
  width: 100%;
  font-size: 24rpx;
  color: var(--neutral-950);
  font-weight: 700;
  text-align: center;
}

.player-gender {
  font-size: 22rpx;
  color: var(--neutral-500);
}

/* Player grid empty state */
.player-grid-empty {
  margin-top: 16rpx;
  padding: 32rpx 16rpx;
  border-radius: 16rpx;
  background: var(--neutral-50);
  border: 1rpx dashed var(--neutral-200);
  text-align: center;
}

.player-grid-empty-text {
  font-size: 25rpx;
  color: var(--neutral-500);
  font-weight: 600;
}

/* --- Profile Panel --- */
.profile-panel {
  padding-top: 20rpx;
}

.profile-col {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.profile-avatar {
  width: 96rpx;
  height: 96rpx;
  border: 2rpx solid var(--neutral-200);
}

.profile-input {
  margin-top: 12rpx;
  text-align: center;
  padding-left: 0;
  padding-right: 0;
}

.profile-inline-tip {
  margin-top: 8rpx;
}

.profile-actions-center {
  width: 100%;
  justify-content: center;
  margin-top: 12rpx;
  margin-bottom: 12rpx;
}

.profile-actions-center .btn-mini {
  min-width: 220rpx;
  background: var(--neutral-100);
}

.profile-actions-center .profile-quick-btn {
  background: linear-gradient(135deg, var(--brand-500), var(--brand-600));
  color: #ffffff;
}

/* --- Join trigger bar --- */
.join-trigger-bar {
  margin-bottom: 16rpx;
}

.join-trigger-btn {
  margin-top: 0 !important;
}

/* --- Bottom-sheet --- */
.sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 100;
}

.join-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg-surface);
  border-radius: 28rpx 28rpx 0 0;
  padding: 16rpx 32rpx calc(env(safe-area-inset-bottom) + 32rpx);
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.32s cubic-bezier(0.32, 0.72, 0, 1);
  box-shadow: 0 -8rpx 30rpx rgba(15, 23, 42, 0.12);
  max-height: 80vh;
  overflow-y: auto;
}

.join-sheet.sheet-open {
  transform: translateY(0);
}

.sheet-handle {
  width: 72rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: var(--neutral-300);
  margin: 0 auto 20rpx;
}

/* --- Share bar (low-profile inline) --- */
.share-bar {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 20rpx;
  background: var(--brand-50);
  border: 1rpx solid var(--brand-100);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.share-bar-left {
  flex: 1;
  min-width: 0;
}

.share-bar-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--brand-700);
}

.share-bar-badge {
  margin-top: 2rpx;
  font-size: 22rpx;
  color: var(--neutral-500);
}

.share-bar-btn {
  flex-shrink: 0;
  width: auto !important;
  min-width: 144rpx;
}

.share-pulse {
  animation: sharePulse 700ms ease-in-out 2;
}

@keyframes sharePulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.03); }
  100% { transform: scale(1); }
}

/* --- Info panel (demoted) --- */
.info-panel {
  background: var(--bg-section);
  border-color: var(--neutral-200);
}

.rule-chips {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.rule-chip {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: var(--bg-surface);
  border: 1rpx solid var(--neutral-200);
  color: var(--neutral-700);
  font-size: 22rpx;
  font-weight: 600;
}

.info-highlight {
  margin-top: 12rpx;
  padding: 12rpx 14rpx;
  border-radius: 14rpx;
  border: 1rpx solid var(--neutral-200);
  background: var(--bg-surface);
  color: var(--neutral-950);
  font-size: 26rpx;
  font-weight: 700;
}

/* --- Admin Panel (visually demoted) --- */
.admin-panel {
  background: var(--neutral-50);
  border-color: var(--neutral-200);
  border-style: dashed;
}

.admin-section-title {
  color: var(--neutral-500);
  font-size: 26rpx;
}

.admin-collapse-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.admin-collapse-arrow {
  font-size: 24rpx;
  color: var(--neutral-500);
  transition: transform 0.2s;
}

.admin-collapse-arrow.expanded {
  transform: rotate(180deg);
}

.admin-manage-actions {
  margin-top: 16rpx;
  display: flex;
  gap: 12rpx;
}

.admin-manage-actions .btn {
  border-radius: 16rpx;
  margin-top: 0 !important;
  flex: 1;
}

.admin-manage-actions .btn[disabled] {
  opacity: 0.72;
  filter: saturate(0.7);
}

/* --- Quick Import --- */
.quick-import {
  margin-top: 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--neutral-200);
  padding: 14rpx;
}

.quick-import-head {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--neutral-950);
}

.quick-import-input {
  margin-top: 8rpx;
  min-height: 160rpx;
}

.quick-import-actions {
  margin-top: 12rpx;
}

.quick-import-result {
  margin-top: 12rpx;
  padding: 12rpx;
  border-radius: 14rpx;
  border: 1rpx solid var(--neutral-200);
  background: var(--neutral-50);
}

.quick-import-result-title {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--neutral-950);
}

/* --- Fixed Team (pair mode) --- */
.fixed-team {
  margin-top: 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--neutral-200);
  padding: 14rpx;
}

.fixed-team-head {
  align-items: center;
}

.fixed-team-list {
  margin-top: 8rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.fixed-team-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  border: 1rpx solid var(--neutral-200);
  border-radius: 14rpx;
  background: var(--bg-surface);
  padding: 10rpx 12rpx;
}

.fixed-team-main {
  flex: 1;
  min-width: 0;
}

.fixed-team-name {
  font-size: 25rpx;
  font-weight: 700;
  color: var(--neutral-950);
}

.fixed-team-create {
  margin-top: 12rpx;
}

.fixed-team-name-input {
  margin-bottom: 8rpx;
}

.fixed-team-create-btn {
  margin-top: 12rpx;
}

/* --- Primary task summary --- */
.primary-task-summary {
  margin-bottom: 8rpx;
}

/* --- Unpaired players hint --- */
.unpaired-hint {
  margin-top: 12rpx;
  padding: 12rpx 14rpx;
  border-radius: 14rpx;
  border: 1rpx solid #FECDD3;
  background: #FFF1F2;
}

.unpaired-hint-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #9F1239;
}

.unpaired-hint-text {
  margin-top: 4rpx;
  font-size: 23rpx;
  color: #BE123C;
  line-height: 1.45;
}

/* --- Quick Config (picker) --- */
.quick-config-row {
  margin-top: 8rpx;
  display: flex;
  gap: 12rpx;
}

.quick-config-col {
  width: calc((100% - 12rpx) / 2);
}

.quick-config-label {
  margin-bottom: 8rpx;
  color: var(--neutral-500);
  font-size: 24rpx;
}

.quick-config-picker {
  min-height: 76rpx;
  line-height: 76rpx;
  border-radius: 14rpx;
  border: 1rpx solid var(--neutral-200);
  background: var(--neutral-100);
  padding: 0 18rpx;
  font-size: 30rpx;
  color: var(--neutral-950);
}

/* --- Loading / Error --- */
.loading-title {
  font-size: 32rpx;
  font-weight: 760;
  margin-bottom: 8rpx;
}

/* --- Player color palette --- */
.pcolor-0 { background: var(--brand-500); }
.pcolor-1 { background: #0ea5e9; }
.pcolor-2 { background: #f59e0b; }
.pcolor-3 { background: #8b5cf6; }
.pcolor-4 { background: #ef4444; }
.pcolor-5 { background: #14b8a6; }

/* --- Responsive --- */
@media (max-width: 360px) {
  .prep-secondary-grid {
    flex-direction: column;
  }

  .player-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}
