<view class="container safe-bottom lobby-page" wx:if="{{tournament}}">
  <view class="sync-banner sync-{{syncStatusTone}}" wx:if="{{syncStatusVisible}}">
    <view class="sync-banner-main">
      <view class="sync-banner-text">{{syncStatusText}}</view>
      <view class="sync-banner-meta" wx:if="{{syncStatusMeta}}">{{syncStatusMeta}}</view>
    </view>
    <text class="sync-banner-action" bindtap="onRetry">{{syncStatusActionText}}</text>
  </view>

  <view class="hero reveal reveal-1">
    <view class="row hero-top">
      <view class="flex-1 minw0">
        <view class="hero-title ellipsis">{{tournament.name}}</view>
        <view class="hero-sub">{{modeLabel}} · 21分制</view>
      </view>
      <view class="tag {{statusClass}}">{{statusText}}</view>
    </view>

    <view class="hero-meta">
      <view class="meta-pill meta-admin" wx:if="{{isAdmin}}">管理员</view>
      <view class="meta-pill meta-player" wx:if="{{myJoined}}">已参赛</view>
    </view>

    <view class="hero-shortcuts" wx:if="{{showScheduleShortcut}}">
      <button class="btn-mini hero-shortcut-btn" bindtap="goSchedule">查看赛程</button>
    </view>

    <view class="kpi">
      <view class="kpi-item">
        <view class="kpi-label">人数</view>
        <view class="kpi-value">{{kpiPlayers}}</view>
      </view>
      <view class="kpi-item">
        <view class="kpi-label">总场次</view>
        <view class="kpi-value">{{kpiMatches}}</view>
      </view>
      <view class="kpi-item">
        <view class="kpi-label">每轮最多</view>
        <view class="kpi-value">{{kpiCourts}}</view>
      </view>
    </view>
  </view>

  <view class="card panel panel-soft state-overview reveal reveal-2" wx:if="{{statePanelSummary}}">
    <view class="section-head">
      <view class="section-title">{{statePanelTitle}}</view>
      <text class="count-pill">{{stateStageBadge}} · {{statePanelRoleLabel}}</text>
    </view>
    <view class="state-panel-summary">{{statePanelSummary}}</view>
    <view class="muted small state-panel-detail" wx:if="{{statePanelDetail}}">{{statePanelDetail}}</view>
    <view class="draft-prep panel-soft state-checklist" wx:if="{{showStateChecklist}}">
      <view class="prep-tile" wx:for="{{checklistItems}}" wx:key="key" data-key="{{item.key}}" bindtap="onChecklistTap">
        <text class="prep-indicator {{item.done ? 'ok' : ''}}"></text>
        <view class="prep-main">
          <view class="prep-title">{{item.title}}</view>
          <view class="prep-sub">{{item.summary}}</view>
        </view>
        <text class="prep-jump">{{item.actionText}}</text>
      </view>
    </view>
    <view class="state-actions" wx:if="{{statePrimaryActionText}}">
      <button class="btn btn-primary state-primary-btn" bindtap="onNextActionTap">{{statePrimaryActionText}}</button>
      <view class="state-secondary-actions" wx:if="{{stateSecondaryActions.length}}">
        <text
          class="link-btn state-secondary-action"
          wx:for="{{stateSecondaryActions}}"
          wx:key="key"
          data-action="{{item.key}}"
          bindtap="onStateSecondaryTap"
        >
          {{item.text}}
        </text>
      </view>
    </view>
  </view>

  <view class="card panel panel-soft profile-panel reveal reveal-3" wx:if="{{showViewOnlyJoinPrompt}}">
    <view class="section-head">
      <view class="section-title">先看比赛信息</view>
      <text class="count-pill">不会自动加入</text>
    </view>
    <view class="muted small profile-hint">当前是只读查看；想参赛时，再点“我要加入”展开资料表单。</view>
    <button class="btn btn-primary" bindtap="enterJoinFromViewOnly">我要加入</button>
  </view>

  <view class="card panel panel-soft profile-panel reveal reveal-3" wx:if="{{showJoin || showMyProfile}}">
    <view class="section-head">
      <view class="section-title">{{showJoin ? '加入比赛' : '我的资料'}}</view>
      <text class="count-pill">{{showJoin ? '草稿可加入' : '草稿可修改'}}</text>
    </view>
    <view class="muted small profile-hint">{{showJoin ? '先补资料，再确认加入。' : '修改后会同步到名单展示。'}}</view>
    <view class="profile-col">
      <image class="avatar-img profile-avatar" src="{{showJoin ? joinAvatarDisplay : myAvatarDisplay}}" mode="aspectFill"></image>
      <input
        class="input profile-input {{profileFieldError ? 'input-error' : ''}}"
        type="nickname"
        focus="{{profileNicknameFocus}}"
        placeholder="{{showJoin ? '昵称（可选）' : '我的昵称'}}"
        value="{{showJoin ? nickname : myNickname}}"
        bindfocus="onProfileNickFocus"
        bindblur="onProfileNickBlur"
        bindinput="onProfileNickInput"
      />
      <view class="muted small profile-inline-tip">可点击输入框使用微信昵称。</view>
      <view class="profile-actions profile-actions-center">
        <button
          class="btn-mini primary profile-quick-btn"
          open-type="chooseAvatar"
          bindchooseavatar="onQuickFillProfile"
          loading="{{profileQuickFillLoading}}"
          disabled="{{profileQuickFillLoading || profileSaving || profileAvatarUploading}}"
        >
          一键填写微信资料
        </button>
        <button class="btn-mini" open-type="chooseAvatar" bindchooseavatar="onChooseAvatarForProfile" disabled="{{profileSaving || profileAvatarUploading}}">仅选头像</button>
      </view>
      <view class="muted small profile-inline-tip" wx:if="{{profileAvatarUploading}}">头像上传中，请稍候…</view>
      <view class="field-error" wx:if="{{profileFieldError}}">{{profileFieldError}}</view>
    </view>
    <view class="squad-chooser" wx:if="{{showJoin && mode==='squad_doubles'}}">
      <view class="field-label">参赛队伍（必选）</view>
      <view class="chips">
        <view class="chip {{joinSquadChoice==='A' ? 'active' : ''}}" data-squad="A" bindtap="onPickJoinSquad">A队</view>
        <view class="chip {{joinSquadChoice==='B' ? 'active' : ''}}" data-squad="B" bindtap="onPickJoinSquad">B队</view>
      </view>
    </view>
    <button class="btn btn-primary" bindtap="submitProfile" loading="{{profileSaving}}" disabled="{{profileSaving || profileQuickFillLoading || profileAvatarUploading}}">{{showJoin ? '确认加入' : '保存我的信息'}}</button>
  </view>

  <view class="card panel share-invite reveal reveal-3" id="share-invite" wx:if="{{tournament && tournament.status==='draft'}}">
    <view class="section-head share-invite-head">
      <view>
        <view class="section-title">{{shareCardTitle}}</view>
        <view class="muted small">{{shareCardHint}}</view>
      </view>
      <text class="count-pill">{{shareCardBadge}}</text>
    </view>
    <button class="btn btn-primary {{sharePulse ? 'share-pulse' : ''}}" open-type="share">{{shareButtonText}}</button>
    <view class="share-invite-meta">
      <view class="muted small">{{shareCardDetailText}}</view>
      <text class="link-btn" wx:if="{{tournament.status==='draft' && isAdmin}}" bindtap="focusQuickImportArea">备用：导入名单</text>
      <text class="link-btn" wx:elif="{{tournament.status!=='draft'}}" bindtap="goRanking">查看排名</text>
    </view>
  </view>

  <view class="card panel admin-panel reveal reveal-4" wx:if="{{showDraftAdminPanel}}">
    <view class="section-head">
      <view class="section-title">管理员主准备区</view>
      <view class="row-right">
        <text class="count-pill">待完成 {{quickChecklistPending}} 项</text>
        <text class="link-btn" bindtap="goSettings">高级参数</text>
      </view>
    </view>

    <view class="quick-config panel-soft" id="quick-config">
      <view class="quick-config-head">比赛参数</view>
      <view class="muted small">按活动时长快速估算总场次</view>
      <view class="quick-config-row">
        <view class="quick-config-col">
          <view class="quick-config-label">总场次</view>
          <picker wx:if="{{useSimpleQuickMPicker}}" mode="selector" range="{{quickConfigMOptions}}" value="{{quickConfigMIndex}}" bindchange="onPickQuickConfigMSimple">
            <view class="picker quick-config-picker">{{quickConfigM}}</view>
          </picker>
          <picker wx:else mode="multiSelector" range="{{quickConfigMDigitRange}}" value="{{quickConfigMDigitValue}}" bindchange="onPickQuickConfigMDigit">
            <view class="picker quick-config-picker">{{quickConfigM}}</view>
          </picker>
        </view>
        <view class="quick-config-col">
          <view class="quick-config-label">每轮最多场数</view>
          <picker mode="selector" range="{{quickConfigCOptions}}" value="{{quickConfigCIndex}}" bindchange="onPickQuickConfigC">
            <view class="picker quick-config-picker">{{quickConfigC}}</view>
          </picker>
        </view>
      </view>
      <view class="quick-config-row">
        <view class="quick-config-col">
          <view class="quick-config-label">活动时长</view>
          <picker mode="selector" range="{{sessionMinuteOptions}}" value="{{sessionMinuteIndex}}" bindchange="onPickSessionMinutes">
            <view class="picker quick-config-picker">{{sessionMinutes}} 分钟</view>
          </picker>
        </view>
        <view class="quick-config-col">
          <view class="quick-config-label">单场占用时间</view>
          <picker mode="selector" range="{{slotMinuteOptions}}" value="{{slotMinuteIndex}}" bindchange="onPickSlotMinutes">
            <view class="picker quick-config-picker">{{slotMinutes}} 分钟</view>
          </picker>
        </view>
      </view>
      <view class="muted small quick-config-tip">{{quickCapacityHintShort}}</view>
      <view class="muted small quick-config-tip" wx:if="{{quickRosterHint}}">{{quickRosterHint}}</view>
      <view class="muted small quick-config-tip" wx:if="{{mode==='fixed_pair_rr' && !pairTeamsUi.length}}">请先在下方完成组队后再开赛</view>
      <button class="btn btn-primary quick-config-save" bindtap="saveQuickSettings">保存参数</button>
    </view>

    <view class="quick-import panel-soft">
      <view class="quick-import-head">备用：导入名单</view>
      <view class="muted small">适合已有名单、代录报名或集中建档。</view>
      <textarea
        id="quick-import"
        class="textarea quick-import-input"
        placeholder="张三/男 李四/女,王五"
        value="{{quickImportText}}"
        focus="{{focusQuickImport}}"
        bindinput="onQuickImportInput"
      ></textarea>
      <view class="btn-row quick-import-actions">
        <button class="btn btn-primary" bindtap="quickImportPlayers">一键导入</button>
      </view>
      <view class="quick-import-result" wx:if="{{importResultText}}">
        <view class="quick-import-result-title">{{importResultText}}</view>
        <view class="muted small" wx:if="{{importResultDetail}}">{{importResultDetail}}</view>
      </view>
    </view>

    <view class="fixed-team panel-soft" wx:if="{{mode==='fixed_pair_rr'}}">
      <view class="fixed-team-head row row-top">
        <view class="quick-import-head">固搭队伍</view>
        <button class="btn-mini" bindtap="autoGeneratePairTeams" loading="{{pairTeamBusy}}" disabled="{{pairTeamBusy}}">自动组队</button>
      </view>
      <view class="muted small">管理员统一组队后即可开赛。</view>

      <view class="fixed-team-list" wx:if="{{pairTeamsUi.length}}">
        <view class="fixed-team-item" wx:for="{{pairTeamsUi}}" wx:key="id">
          <view class="fixed-team-main">
            <view class="fixed-team-name">{{item.name}}</view>
            <view class="muted small">{{item.memberText}}</view>
          </view>
          <button class="btn-mini danger" data-team="{{item.id}}" bindtap="deletePairTeam" disabled="{{pairTeamBusy}}">删除</button>
        </view>
      </view>
      <view class="muted small" wx:else>当前未创建队伍，可先自动组队或手动添加。</view>

      <view class="fixed-team-create" wx:if="{{pairTeamCandidates.length >= 2}}">
        <input class="input fixed-team-name-input" placeholder="队伍名称（可选）" value="{{pairTeamName}}" bindinput="onPairTeamNameInput" />
        <view class="quick-config-row">
          <view class="quick-config-col">
            <view class="quick-config-label">队员1</view>
            <picker mode="selector" range="{{pairTeamCandidates}}" range-key="name" value="{{pairTeamFirstIndex}}" bindchange="onPickPairFirst">
              <view class="picker quick-config-picker">{{pairTeamCandidates[pairTeamFirstIndex].name}}</view>
            </picker>
          </view>
          <view class="quick-config-col">
            <view class="quick-config-label">队员2</view>
            <picker mode="selector" range="{{pairTeamCandidates}}" range-key="name" value="{{pairTeamSecondIndex}}" bindchange="onPickPairSecond">
              <view class="picker quick-config-picker">{{pairTeamCandidates[pairTeamSecondIndex].name}}</view>
            </picker>
          </view>
        </view>
        <button class="btn btn-primary fixed-team-create-btn" bindtap="createPairTeam" loading="{{pairTeamBusy}}" disabled="{{pairTeamBusy}}">添加队伍</button>
      </view>
      <view class="muted small" wx:else>暂无可组队成员（每名成员仅可属于一支队伍）。</view>
    </view>
  </view>

  <view class="card panel reveal reveal-4">
    <view class="section-head">
      <view class="section-title">比赛概览</view>
      <text class="count-pill">{{statusText}}</text>
    </view>
    <view class="rule-chips">
      <text class="rule-chip">{{modeLabel}}</text>
      <text class="rule-chip">{{pointsPerGame}} 分制</text>
      <text class="rule-chip">胜场优先</text>
    </view>
    <view class="info-highlight">{{matchInfoText}}</view>
    <view class="muted small">{{genderSummaryText}}</view>
    <view class="muted small" wx:if="{{tournament.createdAt}}">创建 {{createdAtText}}</view>
  </view>

  <view class="card panel panel-soft reveal reveal-4" wx:if="{{showDraftRules && modeRules.length}}">
    <view class="section-head">
      <view class="section-title">规则说明</view>
      <text class="count-pill">{{modeLabel}}</text>
    </view>
    <view class="muted small" wx:for="{{modeRules}}" wx:key="*this">{{item}}</view>
  </view>

  <view class="card panel reveal reveal-5">
    <view class="section-head">
      <view class="section-title">参赛名单</view>
      <view class="row-right">
        <text class="count-pill">{{tournament.players.length}} 人</text>
        <text class="link-btn" wx:if="{{tournament.players.length>12}}" bindtap="togglePlayers">{{showAllPlayers?'收起':'展开'}}</text>
      </view>
    </view>
    <view class="player-grid" wx:if="{{displayPlayers.length}}">
      <view class="player-cell" wx:for="{{displayPlayers}}" wx:key="id" data-player="{{item.id}}" bindtap="onTogglePlayerSquad">
        <view class="player-avatar {{item.colorClass}}">
          <image class="player-avatar-img" wx:if="{{item.avatarDisplay}}" src="{{item.avatarDisplay}}" mode="aspectFill"></image>
          <text class="player-initial" wx:else>{{item.initial}}</text>
        </view>
        <view class="player-name ellipsis">{{item.name}}</view>
        <view class="player-gender">{{item.genderLabel}}</view>
        <view class="player-gender" wx:if="{{mode==='squad_doubles'}}">{{item.squad ? item.squad + '队' : '未分队'}}</view>
      </view>
    </view>
    <view class="panel-soft list-empty" wx:else>
      <view class="list-empty-title">先分享比赛链接</view>
      <view class="muted small">让大家先看比赛，再决定是否加入；导入名单保留为备用方案。</view>
    </view>
  </view>

  <view class="card panel share-invite reveal reveal-5" id="share-invite" wx:if="{{tournament && tournament.status!=='draft'}}">
    <view class="section-head share-invite-head">
      <view>
        <view class="section-title">{{shareCardTitle}}</view>
        <view class="muted small">{{shareCardHint}}</view>
      </view>
      <text class="count-pill">{{shareCardBadge}}</text>
    </view>
    <button class="btn btn-primary {{sharePulse ? 'share-pulse' : ''}}" open-type="share">{{shareButtonText}}</button>
    <view class="share-invite-meta">
      <view class="muted small">{{shareCardDetailText}}</view>
      <text class="link-btn" wx:if="{{tournament.status==='draft' && isAdmin}}" bindtap="focusQuickImportArea">备用：导入名单</text>
      <text class="link-btn" wx:elif="{{tournament.status!=='draft'}}" bindtap="goRanking">查看排名</text>
    </view>
  </view>

  <view class="card panel panel-soft admin-panel reveal reveal-6" wx:if="{{showAdminMaintenance}}">
    <view class="section-head">
      <view class="section-title">管理员维护</view>
      <text class="count-pill">次级操作</text>
    </view>
    <view class="admin-actions">
      <view class="muted small">赛事已离开草稿阶段，主入口已切到赛程与结果页。</view>
      <button class="btn btn-danger" bindtap="handleReset">重置回草稿</button>
    </view>
  </view>

  <view class="retry-box panel-soft" wx:if="{{canRetryAction}}">
    <view class="muted small">{{lastFailedActionText}}</view>
    <button class="btn btn-subtle btn-sm" bindtap="retryLastAction">重试上次操作</button>
  </view>
</view>

<view class="container safe-bottom" wx:elif="{{loadError}}">
  <view class="card panel reveal reveal-1">
    <view class="loading-title">{{loadErrorTitle}}</view>
    <view class="muted">{{loadErrorMessage}}</view>
    <button class="btn btn-subtle" bindtap="onRetry">重新加载</button>
    <button class="btn btn-ghost" wx:if="{{showLoadErrorHome}}" bindtap="goHome">返回首页</button>
  </view>
</view>

<view class="container" wx:else>
  <view class="card panel reveal reveal-1">
    <view class="loading-title">加载中...</view>
    <view class="muted">若一直加载，请确认分享链接有效且数据库允许读取。</view>
  </view>
</view>
