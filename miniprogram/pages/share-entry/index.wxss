/* ============================================================
   share-entry — 赛事分流入口
   设计方向: 骨架稳定, Hero + Action Rail + Info Grid
   间距遵循 8pt grid, 使用全局 design token
   ============================================================ */

.share-entry-page {
  padding-bottom: calc(env(safe-area-inset-bottom) + 32rpx);
}

/* --- Sync Banner (hidden 替代 wx:if, 无 layout shift) --- */
/* 继承全局 .sync-banner 基类, 无需重复定义 */

/* --- Hero: 绿色渐变赛事 Hero --- */
.share-hero {
  margin-top: 0;
  padding: 32rpx 24rpx 28rpx;
}

.share-hero .hero-top {
  gap: 16rpx;
  align-items: flex-start;
}

.share-title {
  font-size: 40rpx;
  font-weight: 820;
  color: #ffffff;
  line-height: 1.2;
  letter-spacing: -0.3rpx;
}

.share-headline {
  margin-top: 8rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.88);
  line-height: 1.4;
}

.share-pills {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.share-pill {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
}

/* --- Action Rail: 固定中间区域 --- */
.share-decision {
  margin-top: 16rpx;
  padding: 20rpx;
}

/* --- Availability 状态指示 --- */
.share-availability {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  background: var(--neutral-50);
  border: 1rpx solid var(--neutral-200);
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.share-availability.is-pending {
  background: var(--info-100);
  border-color: #BFDBFE;
}

.share-availability.is-timeout {
  background: #FEF3C7;
  border-color: #FCD34D;
}

.share-availability-icon {
  flex-shrink: 0;
  width: 40rpx;
  height: 40rpx;
  border-radius: 999rpx;
  background: var(--neutral-200);
  color: var(--neutral-700);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 800;
}

.share-availability.is-pending .share-availability-icon {
  background: #BFDBFE;
  color: #1D4ED8;
}

.share-availability.is-timeout .share-availability-icon {
  background: #FCD34D;
  color: #92400E;
}

.share-availability-body {
  flex: 1;
  min-width: 0;
}

.share-availability-title {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--neutral-950);
  line-height: 1.4;
}

.share-availability-text {
  margin-top: 4rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--neutral-500);
}

.share-availability.is-pending .share-availability-title {
  color: #1D4ED8;
}

.share-availability.is-timeout .share-availability-title {
  color: #92400E;
}

/* --- Squad Chooser --- */
.card-inline-squad {
  margin-top: 16rpx;
}

.squad-chooser {
  margin-top: 0;
}

/* --- Action Buttons --- */
.share-actions {
  margin-top: 16rpx;
}

.share-actions .btn + .btn {
  margin-top: 8rpx;
}

.share-actions .btn-row {
  margin-top: 8rpx;
}

/* --- Info Card: 2-col 紧凑网格 --- */
.share-info {
  margin-top: 16rpx;
}

.share-facts {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8rpx;
}

.share-fact {
  padding: 12rpx 14rpx;
  border-radius: 12rpx;
  background: var(--neutral-50);
  border: 1rpx solid var(--neutral-200);
}

.share-fact-label {
  display: block;
  color: var(--neutral-500);
  font-size: 22rpx;
  line-height: 1.4;
}

.share-fact-value {
  display: block;
  margin-top: 4rpx;
  color: var(--neutral-950);
  font-size: 26rpx;
  font-weight: 720;
  line-height: 1.4;
  word-break: break-word;
}

/* --- Error / Invalid State --- */
.share-error-panel {
  margin-top: 16rpx;
}

.share-error-panel .state-error {
  padding: 32rpx 16rpx;
}

.share-error-panel .state-error-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  background: #FEE2E2;
  color: var(--danger);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
}
