.share-entry-page {
  padding-bottom: calc(env(safe-area-inset-bottom) + 28rpx);
}

.sync-banner {
  margin-bottom: 12rpx;
  padding: 12rpx 16rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.sync-warning {
  background: #fef3c7;
  border: 1rpx solid #fcd34d;
  color: #92400e;
}

.sync-info {
  background: #eff6ff;
  border: 1rpx solid #bfdbfe;
  color: #1d4ed8;
}

.sync-neutral {
  background: #f8fafc;
  border: 1rpx solid #dbe5ef;
  color: #334155;
}

.sync-banner-main {
  flex: 1;
  min-width: 0;
}

.sync-banner-text {
  font-size: 23rpx;
  font-weight: 700;
}

.sync-banner-meta {
  margin-top: 4rpx;
  font-size: 21rpx;
  line-height: 1.5;
  opacity: 0.88;
}

.sync-banner-action {
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 760;
}

.share-hero {
  margin-top: 12rpx;
}

.share-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #0f172a;
  line-height: 1.25;
}

.share-headline {
  margin-top: 10rpx;
  font-size: 28rpx;
  font-weight: 720;
  color: #14804b;
}

.share-subtitle {
  margin-top: 12rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.6;
}

.share-pills {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.share-info {
  margin-top: 16rpx;
}

.share-facts {
  margin-top: 12rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.share-fact {
  padding: 16rpx;
  border-radius: 18rpx;
  background: #f8fbff;
  border: 1rpx solid #dce7f2;
}

.share-fact-label {
  display: block;
  color: #64748b;
  font-size: 22rpx;
}

.share-fact-value {
  display: block;
  margin-top: 8rpx;
  color: #0f172a;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.5;
  word-break: break-word;
}

.share-note {
  margin-top: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: #f5faf6;
  border: 1rpx solid #d7e9dd;
  color: #166534;
  font-size: 24rpx;
  line-height: 1.6;
}

.squad-chooser {
  margin-top: 14rpx;
}

.progress-summary {
  margin-top: 12rpx;
}

.summary-value {
  font-size: 30rpx;
  font-weight: 760;
  color: #0f172a;
  margin-bottom: 8rpx;
}

.ranking-preview {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.ranking-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: #f8fbff;
  border: 1rpx solid #dce7f2;
}

.ranking-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.ranking-rank {
  font-size: 24rpx;
  font-weight: 760;
  color: #14804b;
}

.ranking-name {
  font-size: 25rpx;
  font-weight: 700;
  color: #0f172a;
}

.ranking-right {
  flex: 1;
  text-align: right;
  font-size: 22rpx;
  color: #64748b;
}

.share-actions {
  margin-top: 18rpx;
}

.share-actions .btn + .btn {
  margin-top: 12rpx;
}
