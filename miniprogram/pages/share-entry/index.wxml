<view class="container safe-bottom share-entry-page">
  <view class="sync-banner sync-{{syncStatusTone}}" wx:if="{{syncStatusVisible}}">
    <view class="sync-banner-main">
      <view class="sync-banner-text">{{syncStatusText}}</view>
      <view class="sync-banner-meta" wx:if="{{syncStatusMeta}}">{{syncStatusMeta}}</view>
    </view>
    <text class="sync-banner-action" bindtap="onRetry">{{syncStatusActionText}}</text>
  </view>

  <view class="card panel share-hero reveal reveal-1">
    <view class="row hero-top">
      <view class="flex-1 minw0">
        <view class="share-title">{{preview.tournamentName}}</view>
      <view class="share-headline">{{preview.headline}}</view>
      </view>
      <view class="tag {{preview.statusClass}}">{{preview.statusText}}</view>
    </view>
    <view class="share-pills">
      <text class="rule-chip">{{preview.modeLabel}}</text>
      <text class="rule-chip">{{preview.playersCountText}}</text>
      <text class="rule-chip">{{preview.joinAllowed ? '可加入' : '当前不可加入'}}</text>
    </view>
  </view>

  <view class="card panel panel-soft share-decision reveal reveal-2">
    <view class="section-head">
      <view class="section-title">现在可以做什么</view>
      <text class="count-pill">{{preview.viewModeLabel}}</text>
    </view>
    <view
      class="share-availability {{identityPending ? 'is-pending' : ''}} {{identityTimedOut ? 'is-timeout' : ''}}"
      wx:if="{{preview.availabilityText}}"
    >
      <view class="share-availability-title">{{identityPending ? '身份识别中' : (identityTimedOut ? '先看比赛' : '操作提示')}}</view>
      <view class="share-availability-text">{{preview.availabilityText}}</view>
    </view>
    <view class="card-inline-squad" wx:if="{{tournament && tournament.mode==='squad_doubles' && preview.joinAllowed && !preview.joined}}">
      <view class="chips squad-chooser">
        <view class="chip {{joinSquadChoice==='A' ? 'active' : ''}}" data-squad="A" bindtap="onPickJoinSquad">A队</view>
        <view class="chip {{joinSquadChoice==='B' ? 'active' : ''}}" data-squad="B" bindtap="onPickJoinSquad">B队</view>
      </view>
    </view>
    <view class="share-actions">
      <button
        class="btn btn-primary"
        bindtap="onPrimaryAction"
        loading="{{joinBusy}}"
        disabled="{{joinBusy || preview.primaryAction.key==='identity_pending'}}"
      >
        {{preview.primaryAction.text}}
      </button>
      <view class="btn-row" wx:if="{{tournament && tournament.status !== 'draft'}}">
        <button class="btn btn-subtle" bindtap="goSchedule" wx:if="{{tournament.status === 'running'}}">查看赛程</button>
        <button class="btn btn-subtle" bindtap="goRanking" wx:if="{{tournament.status === 'running'}}">查看排名</button>
        <button class="btn btn-subtle" bindtap="goAnalytics" wx:if="{{tournament.status === 'finished'}}">查看赛事复盘</button>
        <button class="btn btn-subtle" bindtap="goRanking" wx:if="{{tournament.status === 'finished'}}">查看排名</button>
      </view>
      <button
        class="btn btn-subtle"
        wx:if="{{preview.secondaryAction && (preview.viewMode==='invalid-match' || preview.viewMode==='retryable-error')}}"
        bindtap="onSecondaryAction"
      >
        {{preview.secondaryAction.text}}
      </button>
    </view>
  </view>

  <view class="card panel share-info reveal reveal-3">
    <view class="section-head">
      <view class="section-title">比赛摘要</view>
      <text class="count-pill">{{preview.viewModeLabel}}</text>
    </view>
    <view class="share-facts">
      <view class="share-fact">
        <text class="share-fact-label">组织者</text>
        <text class="share-fact-value">{{preview.organizerName}}</text>
      </view>
      <view class="share-fact">
        <text class="share-fact-label">状态</text>
        <text class="share-fact-value">{{preview.statusText}}</text>
      </view>
      <view class="share-fact">
        <text class="share-fact-label">人数</text>
        <text class="share-fact-value">{{preview.playersCountText}}</text>
      </view>
      <view class="share-fact">
        <text class="share-fact-label">进度</text>
        <text class="share-fact-value">{{preview.progressText}}</text>
      </view>
      <view class="share-fact">
        <text class="share-fact-label">时间</text>
        <text class="share-fact-value">{{preview.timeText}}</text>
      </view>
      <view class="share-fact">
        <text class="share-fact-label">地点</text>
        <text class="share-fact-value">{{preview.venueText}}</text>
      </view>
    </view>
  </view>

  <view class="card panel panel-soft" wx:if="{{loadError && !tournament}}">
    <view class="section-title">{{preview.headline}}</view>
    <view class="muted">{{preview.subtitle}}</view>
  </view>
</view>
