/* Ranking 页面样式 — 积分榜风 */

.ranking-page {
  padding-top: 24rpx;
}

/* --- Hero 积分榜感 --- */
.hero-kicker {
  font-size: 22rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.72);
  letter-spacing: 0.5rpx;
  text-transform: uppercase;
}

/* --- Ranking Card --- */
.ranking-card {
  margin-top: 12rpx;
}

.ranking-card-top {
  border-color: rgba(24, 179, 104, 0.15);
  background: var(--bg-surface);
}

.ranking-card-1st {
  border-color: rgba(245, 158, 11, 0.25);
  background: linear-gradient(135deg, #FFFBEB 0%, var(--bg-surface) 100%);
  box-shadow: 0 4rpx 16rpx rgba(245, 158, 11, 0.08);
}

.ranking-card-2nd {
  border-color: rgba(148, 163, 184, 0.3);
  background: linear-gradient(135deg, var(--neutral-50) 0%, var(--bg-surface) 100%);
  box-shadow: 0 4rpx 16rpx rgba(100, 116, 139, 0.06);
}

.ranking-card-3rd {
  border-color: rgba(217, 119, 6, 0.2);
  background: linear-gradient(135deg, #FFF7ED 0%, var(--bg-surface) 100%);
  box-shadow: 0 4rpx 16rpx rgba(217, 119, 6, 0.06);
}

.ranking-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.ranking-left {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.player-title {
  font-size: 30rpx;
  font-weight: 760;
  color: var(--neutral-950);
}

.ranking-right {
  flex-shrink: 0;
  text-align: right;
}

.metric-title {
  font-size: 28rpx;
  font-weight: 780;
  color: var(--neutral-950);
}

/* --- Trend Pill 紧凑化 --- */
.trend-pill {
  margin-top: 4rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 88rpx;
  padding: 2rpx 8rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
  border: 1rpx solid var(--neutral-200);
  color: var(--neutral-500);
  background: var(--neutral-50);
}

.trend-pill.up {
  color: var(--brand-700);
  border-color: var(--brand-100);
  background: var(--brand-50);
}

.trend-pill.down {
  color: #9F1239;
  border-color: #FECDD3;
  background: #FFF1F2;
}

/* --- Empty Title (兼容) --- */
.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  color: var(--neutral-700);
}

/* --- Ranking Skeleton --- */
.ranking-skeleton-list {
  margin-top: 8rpx;
}
