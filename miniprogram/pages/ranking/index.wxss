.ranking-page {
  padding-top: 24rpx;
}

.ranking-empty {
  margin-top: 18rpx;
}

.ranking-empty-btn {
  margin-top: 12rpx;
  width: auto;
  min-width: 220rpx;
  padding: 0 24rpx;
}

.ranking-card {
  margin-top: 14rpx;
}

.ranking-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.ranking-left {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.player-title {
  font-size: 30rpx;
  font-weight: 760;
}

.ranking-right {
  text-align: right;
}

.trend-pill {
  margin-top: 6rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 96rpx;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  border: 1rpx solid #dbe5ef;
  color: #64748b;
  background: #f8fbff;
}

.trend-pill.up {
  color: #166534;
  border-color: #bbf7d0;
  background: #ecfdf3;
}

.trend-pill.down {
  color: #9f1239;
  border-color: #fecdd3;
  background: #fff1f2;
}

.metric-title {
  font-size: 28rpx;
  font-weight: 760;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 760;
  margin-bottom: 8rpx;
}
