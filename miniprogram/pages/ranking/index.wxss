.ranking-page {
  padding-top: 24rpx;
}

.ranking-empty {
  margin-top: 18rpx;
}

.ranking-empty-btn {
  margin-top: 12rpx;
  width: auto;
  min-width: 220rpx;
  padding: 0 24rpx;
}

.ranking-card {
  margin-top: 14rpx;
}

.ranking-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.ranking-left {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.player-title {
  font-size: 30rpx;
  font-weight: 760;
}

.ranking-right {
  text-align: right;
}

.metric-title {
  font-size: 28rpx;
  font-weight: 760;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 760;
  margin-bottom: 8rpx;
}
